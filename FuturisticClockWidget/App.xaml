<Application x:Class="FuturisticClockWidget.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <!-- Futuristic Color Palette -->
        <SolidColorBrush x:Key="PrimaryAccent" Color="#00D4FF"/>
        <SolidColorBrush x:Key="SecondaryAccent" Color="#FF00FF"/>
        <SolidColorBrush x:Key="BackgroundDark" Color="#0A0A0A"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#B0B0B0"/>
        
        <!-- Glass Effect Brush -->
        <LinearGradientBrush x:Key="GlassBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#1A1A1A" Offset="0"/>
            <GradientStop Color="#2A2A2A" Offset="1"/>
        </LinearGradientBrush>
        
        <!-- Neon Glow Effect -->
        <RadialGradientBrush x:Key="NeonGlowBrush">
            <GradientStop Color="#00D4FF" Offset="0"/>
            <GradientStop Color="#00D4FF00" Offset="1"/>
        </RadialGradientBrush>
    </Application.Resources>
</Application>
