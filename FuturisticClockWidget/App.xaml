<Application x:Class="FuturisticClockWidget.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <!-- Enhanced Futuristic Color Palette -->
        <SolidColorBrush x:Key="PrimaryAccent" Color="#00D4FF"/>
        <SolidColorBrush x:Key="SecondaryAccent" Color="#FF6B9D"/>
        <SolidColorBrush x:Key="BackgroundDark" Color="#0A0A0A"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#B0B0B0"/>
        
        <!-- Glassmorphism Brushes -->
        <LinearGradientBrush x:Key="GlassBorderBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#40FFFFFF" Offset="0"/>
            <GradientStop Color="#20FFFFFF" Offset="0.5"/>
            <GradientStop Color="#30FFFFFF" Offset="1"/>
        </LinearGradientBrush>
        
        <RadialGradientBrush x:Key="GlassBackgroundBrush">
            <GradientStop Color="#0F000000" Offset="0"/>
            <GradientStop Color="#15000000" Offset="0.5"/>
            <GradientStop Color="#0A000000" Offset="1"/>
        </RadialGradientBrush>
        
        <LinearGradientBrush x:Key="GlassHighlightBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#60FFFFFF" Offset="0"/>
            <GradientStop Color="#30FFFFFF" Offset="0.5"/>
            <GradientStop Color="#00FFFFFF" Offset="1"/>
        </LinearGradientBrush>
        
        <!-- Enhanced Neon Glow Effects -->
        <RadialGradientBrush x:Key="NeonGlowBrush">
            <GradientStop Color="#00D4FF" Offset="0"/>
            <GradientStop Color="#00D4FF40" Offset="0.5"/>
            <GradientStop Color="#00D4FF00" Offset="1"/>
        </RadialGradientBrush>
        
        <LinearGradientBrush x:Key="CyanGlowBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#00D4FF" Offset="0"/>
            <GradientStop Color="#00A8CC" Offset="0.5"/>
            <GradientStop Color="#0088AA" Offset="1"/>
        </LinearGradientBrush>
    </Application.Resources>
</Application>
