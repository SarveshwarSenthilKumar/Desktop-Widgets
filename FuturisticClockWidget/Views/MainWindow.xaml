<Window x:Class="FuturisticClockWidget.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Futuristic Clock Widget" 
        Height="140" Width="280"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseRightButtonDown="Window_MouseRightButtonDown"
        SizeChanged="Window_SizeChanged">
    
    <Window.Resources>
        <!-- Neon Text Style -->
        <Style x:Key="NeonTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Light"/>
            <Setter Property="FontWeight" Value="UltraLight"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#00D4FF" 
                                      BlurRadius="15" 
                                      ShadowDepth="0" 
                                      Opacity="0.8"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Minimalist Date Style -->
        <Style x:Key="DateTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Semilight"/>
            <Setter Property="FontWeight" Value="Light"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#00D4FF" 
                                      BlurRadius="8" 
                                      ShadowDepth="0" 
                                      Opacity="0.5"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Small Info Style -->
        <Style x:Key="SmallInfoStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="Light"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="8"/>
            <Setter Property="Foreground" Value="#88FFFFFF"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#00D4FF" 
                                      BlurRadius="6" 
                                      ShadowDepth="0" 
                                      Opacity="0.4"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Liquid Animation -->
        <Storyboard x:Key="LiquidAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                           From="0.7" To="0.95" Duration="0:0:3"
                           AutoReverse="true">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>
    
        <!-- Enhanced Glassmorphism Container -->
    <Border CornerRadius="24" 
            BorderThickness="1">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0D000000" Offset="0"/>
                <GradientStop Color="#15000000" Offset="0.5"/>
                <GradientStop Color="#0A000000" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#30FFFFFF" Offset="0"/>
                <GradientStop Color="#15FFFFFF" Offset="0.5"/>
                <GradientStop Color="#25FFFFFF" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.ContextMenu>
            <ContextMenu Background="#0F000000" Foreground="#FFFFFF">
                <ContextMenu.Resources>
                    <Style TargetType="MenuItem">
                        <Setter Property="Background" Value="#0F000000"/>
                        <Setter Property="Foreground" Value="#00D4FF"/>
                        <Setter Property="BorderBrush" Value="#3000D4FF"/>
                        <Setter Property="FontFamily" Value="Segoe UI Light"/>
                    </Style>
                    <Style TargetType="Separator">
                        <Setter Property="Background" Value="#3000D4FF"/>
                    </Style>
                </ContextMenu.Resources>
                <MenuItem Header="Size">
                    <MenuItem Header="Small (200x100)" Click="SizeSmall_Click"/>
                    <MenuItem Header="Medium (280x140)" Click="SizeMedium_Click"/>
                    <MenuItem Header="Large (400x200)" Click="SizeLarge_Click"/>
                    <MenuItem Header="Extra Large (600x300)" Click="SizeExtraLarge_Click"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Time Format">
                    <MenuItem Header="12-Hour (Normal)" Click="Format12Hour_Click"/>
                    <MenuItem Header="24-Hour (Military)" Click="Format24Hour_Click"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Close" Click="CloseMenuItem_Click"/>
            </ContextMenu>
        </Border.ContextMenu>
        <Border.Effect>
            <DropShadowEffect Color="#00D4FF" 
                            BlurRadius="25" 
                            ShadowDepth="0" 
                            Opacity="0.4"/>
        </Border.Effect>
        
        <!-- Enhanced Glass Layers -->
        <Grid>
            <!-- Background Blur Layer -->
            <Border CornerRadius="22" Margin="1">
                <Border.Background>
                    <RadialGradientBrush>
                        <GradientStop Color="#0F111111" Offset="0"/>
                        <GradientStop Color="#0A222222" Offset="0.7"/>
                        <GradientStop Color="#05333333" Offset="1"/>
                    </RadialGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <BlurEffect Radius="8" KernelType="Gaussian"/>
                </Border.Effect>
                <Border.OpacityMask>
                    <RadialGradientBrush>
                        <GradientStop Color="#FFFFFF" Offset="0"/>
                        <GradientStop Color="#CCFFFFFF" Offset="0.8"/>
                        <GradientStop Color="#AAFFFFFF" Offset="1"/>
                    </RadialGradientBrush>
                </Border.OpacityMask>
            </Border>
            
            <!-- Glass Reflection Layer -->
            <Border CornerRadius="20" Margin="2">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#25FFFFFF" Offset="0"/>
                        <GradientStop Color="#10FFFFFF" Offset="0.3"/>
                        <GradientStop Color="#08FFFFFF" Offset="0.7"/>
                        <GradientStop Color="#15FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            
            <!-- Top Highlight Layer -->
            <Border CornerRadius="20" Margin="2" Height="20" VerticalAlignment="Top">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#40FFFFFF" Offset="0"/>
                        <GradientStop Color="#20FFFFFF" Offset="0.5"/>
                        <GradientStop Color="#00FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.OpacityMask>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FFFFFF" Offset="0"/>
                        <GradientStop Color="#FFFFFF" Offset="0.5"/>
                        <GradientStop Color="#00FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.OpacityMask>
            </Border>
            
            <!-- Content Layer -->
            <Grid Margin="25,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Main Content -->
                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Time Display -->
                    <TextBlock Grid.Row="0"
                             x:Name="TimeTextBlock"
                             Text="{Binding FormattedTime}"
                             Style="{StaticResource NeonTextStyle}"
                             FontSize="28"
                             Foreground="#00D4FF">
                        <TextBlock.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard Storyboard="{StaticResource LiquidAnimation}"/>
                            </EventTrigger>
                        </TextBlock.Triggers>
                    </TextBlock>
                    
                    <!-- Full Date Display -->
                    <TextBlock Grid.Row="1"
                             Text="{Binding CurrentDate, StringFormat='{}{0:dddd, MMMM dd, yyyy}'}"
                             Style="{StaticResource DateTextStyle}"
                             FontSize="10"
                             Foreground="#CCFFFFFF"
                             Margin="0,2,0,0"/>
                    
                    <!-- Additional Info Row -->
                    <Grid Grid.Row="2" Margin="0,3,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Week Number -->
                        <TextBlock Grid.Column="0"
                                 Text="{Binding WeekNumber}"
                                 Style="{StaticResource SmallInfoStyle}"/>
                        
                        <!-- Day of Year -->
                        <TextBlock Grid.Column="1"
                                 Text="{Binding DayOfYear}"
                                 Style="{StaticResource SmallInfoStyle}"/>
                    </Grid>
                    
                    <!-- Time Zone Info -->
                    <TextBlock Grid.Row="3"
                             Text="{Binding TimeZoneDisplay}"
                             Style="{StaticResource SmallInfoStyle}"
                             Margin="0,1,0,0"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
