<Window x:Class="FuturisticClockWidget.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Futuristic Clock Widget" 
        Height="140" Width="280"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseRightButtonDown="Window_MouseRightButtonDown"
        SizeChanged="Window_SizeChanged">
    
    <Window.Resources>
        <!-- Neon Text Style -->
        <Style x:Key="NeonTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Light"/>
            <Setter Property="FontWeight" Value="UltraLight"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#00FFFF" 
                                      BlurRadius="12" 
                                      ShadowDepth="0" 
                                      Opacity="0.6"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Minimalist Date Style -->
        <Style x:Key="DateTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Semilight"/>
            <Setter Property="FontWeight" Value="Light"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#00FFFF" 
                                      BlurRadius="6" 
                                      ShadowDepth="0" 
                                      Opacity="0.4"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Small Info Style -->
        <Style x:Key="SmallInfoStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="Light"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="8"/>
            <Setter Property="Foreground" Value="#88FFFFFF"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#00FFFF" 
                                      BlurRadius="4" 
                                      ShadowDepth="0" 
                                      Opacity="0.3"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Liquid Animation -->
        <Storyboard x:Key="LiquidAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                           From="0.7" To="0.95" Duration="0:0:3"
                           AutoReverse="true">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>
    
    <!-- Liquid Glass Container -->
    <Border CornerRadius="20" 
            Background="#0A000000"
            BorderThickness="0">
        <Border.ContextMenu>
            <ContextMenu Background="#0A000000" Foreground="#FFFFFF">
                <ContextMenu.Resources>
                    <Style TargetType="MenuItem">
                        <Setter Property="Background" Value="#0A000000"/>
                        <Setter Property="Foreground" Value="#00FFFF"/>
                        <Setter Property="BorderBrush" Value="#2000FFFF"/>
                        <Setter Property="FontFamily" Value="Segoe UI Light"/>
                    </Style>
                    <Style TargetType="Separator">
                        <Setter Property="Background" Value="#2000FFFF"/>
                    </Style>
                </ContextMenu.Resources>
                <MenuItem Header="Size">
                    <MenuItem Header="Small (200x100)" Click="SizeSmall_Click"/>
                    <MenuItem Header="Medium (280x140)" Click="SizeMedium_Click"/>
                    <MenuItem Header="Large (400x200)" Click="SizeLarge_Click"/>
                    <MenuItem Header="Extra Large (600x300)" Click="SizeExtraLarge_Click"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Time Format">
                    <MenuItem Header="12-Hour (Normal)" Click="Format12Hour_Click"/>
                    <MenuItem Header="24-Hour (Military)" Click="Format24Hour_Click"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Close" Click="CloseMenuItem_Click"/>
            </ContextMenu>
        </Border.ContextMenu>
        <Border.Effect>
            <DropShadowEffect Color="#00FFFF" 
                            BlurRadius="20" 
                            ShadowDepth="0" 
                            Opacity="0.3"/>
        </Border.Effect>
        
        <!-- Liquid Glass Layers -->
        <Grid>
            <!-- Background Blur Layer -->
            <Border CornerRadius="18" Margin="1">
                <Border.Background>
                    <RadialGradientBrush>
                        <GradientStop Color="#0F111111" Offset="0"/>
                        <GradientStop Color="#0A222222" Offset="1"/>
                    </RadialGradientBrush>
                </Border.Background>
                <Border.OpacityMask>
                    <RadialGradientBrush>
                        <GradientStop Color="#FFFFFF" Offset="0"/>
                        <GradientStop Color="#AAFFFFFF" Offset="1"/>
                    </RadialGradientBrush>
                </Border.OpacityMask>
            </Border>
            
            <!-- Glass Reflection Layer -->
            <Border CornerRadius="16" Margin="2">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#15FFFFFF" Offset="0"/>
                        <GradientStop Color="#05FFFFFF" Offset="0.5"/>
                        <GradientStop Color="#10FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            
            <!-- Content Layer -->
            <Grid Margin="20,15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Main Content -->
                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Time Display -->
                    <TextBlock Grid.Row="0"
                             x:Name="TimeTextBlock"
                             Text="{Binding FormattedTime}"
                             Style="{StaticResource NeonTextStyle}"
                             FontSize="28"
                             Foreground="#00FFFF">
                        <TextBlock.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard Storyboard="{StaticResource LiquidAnimation}"/>
                            </EventTrigger>
                        </TextBlock.Triggers>
                    </TextBlock>
                    
                    <!-- Full Date Display -->
                    <TextBlock Grid.Row="1"
                             Text="{Binding CurrentDate, StringFormat='{}{0:dddd, MMMM dd, yyyy}'}"
                             Style="{StaticResource DateTextStyle}"
                             FontSize="10"
                             Foreground="#AAFFFFFF"
                             Margin="0,2,0,0"/>
                    
                    <!-- Additional Info Row -->
                    <Grid Grid.Row="2" Margin="0,3,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Week Number -->
                        <TextBlock Grid.Column="0"
                                 Text="{Binding WeekNumber}"
                                 Style="{StaticResource SmallInfoStyle}"/>
                        
                        <!-- Day of Year -->
                        <TextBlock Grid.Column="1"
                                 Text="{Binding DayOfYear}"
                                 Style="{StaticResource SmallInfoStyle}"/>
                    </Grid>
                    
                    <!-- Time Zone Info -->
                    <TextBlock Grid.Row="3"
                             Text="{Binding TimeZoneDisplay}"
                             Style="{StaticResource SmallInfoStyle}"
                             Margin="0,1,0,0"/>
                </Grid>
            </Grid>
            
            <!-- Corner Resize Grips -->
            <!-- Top-Left Corner -->
            <Grid HorizontalAlignment="Left" 
                  VerticalAlignment="Top" 
                  Width="15" 
                  Height="15"
                  Cursor="SizeNWSE"
                  MouseLeftButtonDown="CornerResize_MouseLeftButtonDown"
                  MouseMove="CornerResize_MouseMove"
                  MouseLeftButtonUp="CornerResize_MouseLeftButtonUp"
                  Tag="TopLeft">
                <Grid.Background>
                    <SolidColorBrush Color="Transparent"/>
                </Grid.Background>
                <Path Data="M 15,0 L 15,15 M 0,15 L 15,15" 
                      Stroke="#30FFFFFF" 
                      StrokeThickness="1" 
                      Opacity="0.4"/>
            </Grid>
            
            <!-- Top-Right Corner -->
            <Grid HorizontalAlignment="Right" 
                  VerticalAlignment="Top" 
                  Width="15" 
                  Height="15"
                  Cursor="SizeNESW"
                  MouseLeftButtonDown="CornerResize_MouseLeftButtonDown"
                  MouseMove="CornerResize_MouseMove"
                  MouseLeftButtonUp="CornerResize_MouseLeftButtonUp"
                  Tag="TopRight">
                <Grid.Background>
                    <SolidColorBrush Color="Transparent"/>
                </Grid.Background>
                <Path Data="M 0,0 L 0,15 M 0,15 L 15,15" 
                      Stroke="#30FFFFFF" 
                      StrokeThickness="1" 
                      Opacity="0.4"/>
            </Grid>
            
            <!-- Bottom-Left Corner -->
            <Grid HorizontalAlignment="Left" 
                  VerticalAlignment="Bottom" 
                  Width="15" 
                  Height="15"
                  Cursor="SizeNESW"
                  MouseLeftButtonDown="CornerResize_MouseLeftButtonDown"
                  MouseMove="CornerResize_MouseMove"
                  MouseLeftButtonUp="CornerResize_MouseLeftButtonUp"
                  Tag="BottomLeft">
                <Grid.Background>
                    <SolidColorBrush Color="Transparent"/>
                </Grid.Background>
                <Path Data="M 15,0 L 15,15 M 0,0 L 15,0" 
                      Stroke="#30FFFFFF" 
                      StrokeThickness="1" 
                      Opacity="0.4"/>
            </Grid>
            
            <!-- Bottom-Right Corner -->
            <Grid HorizontalAlignment="Right" 
                  VerticalAlignment="Bottom" 
                  Width="15" 
                  Height="15"
                  Cursor="SizeNWSE"
                  MouseLeftButtonDown="CornerResize_MouseLeftButtonDown"
                  MouseMove="CornerResize_MouseMove"
                  MouseLeftButtonUp="CornerResize_MouseLeftButtonUp"
                  Tag="BottomRight">
                <Grid.Background>
                    <SolidColorBrush Color="Transparent"/>
                </Grid.Background>
                <Path Data="M 0,0 L 15,0 M 0,15 L 15,15" 
                      Stroke="#30FFFFFF" 
                      StrokeThickness="1" 
                      Opacity="0.4"/>
            </Grid>
            
            <!-- Edge Resize Grips -->
            <!-- Top Edge -->
            <Grid HorizontalAlignment="Stretch" 
                  VerticalAlignment="Top" 
                  Height="8"
                  Margin="15,0,15,0"
                  Cursor="SizeNS"
                  MouseLeftButtonDown="EdgeResize_MouseLeftButtonDown"
                  MouseMove="EdgeResize_MouseMove"
                  MouseLeftButtonUp="EdgeResize_MouseLeftButtonUp"
                  Tag="Top">
                <Grid.Background>
                    <SolidColorBrush Color="Transparent"/>
                </Grid.Background>
            </Grid>
            
            <!-- Bottom Edge -->
            <Grid HorizontalAlignment="Stretch" 
                  VerticalAlignment="Bottom" 
                  Height="8"
                  Margin="15,0,15,0"
                  Cursor="SizeNS"
                  MouseLeftButtonDown="EdgeResize_MouseLeftButtonDown"
                  MouseMove="EdgeResize_MouseMove"
                  MouseLeftButtonUp="EdgeResize_MouseLeftButtonUp"
                  Tag="Bottom">
                <Grid.Background>
                    <SolidColorBrush Color="Transparent"/>
                </Grid.Background>
            </Grid>
            
            <!-- Left Edge -->
            <Grid HorizontalAlignment="Left" 
                  VerticalAlignment="Stretch" 
                  Width="8"
                  Margin="0,15,0,15"
                  Cursor="SizeWE"
                  MouseLeftButtonDown="EdgeResize_MouseLeftButtonDown"
                  MouseMove="EdgeResize_MouseMove"
                  MouseLeftButtonUp="EdgeResize_MouseLeftButtonUp"
                  Tag="Left">
                <Grid.Background>
                    <SolidColorBrush Color="Transparent"/>
                </Grid.Background>
            </Grid>
            
            <!-- Right Edge -->
            <Grid HorizontalAlignment="Right" 
                  VerticalAlignment="Stretch" 
                  Width="8"
                  Margin="0,15,0,15"
                  Cursor="SizeWE"
                  MouseLeftButtonDown="EdgeResize_MouseLeftButtonDown"
                  MouseMove="EdgeResize_MouseMove"
                  MouseLeftButtonUp="EdgeResize_MouseLeftButtonUp"
                  Tag="Right">
                <Grid.Background>
                    <SolidColorBrush Color="Transparent"/>
                </Grid.Background>
            </Grid>
        </Grid>
    </Border>
</Window>
