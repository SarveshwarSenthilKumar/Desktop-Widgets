<Window x:Class="FuturisticClockWidget.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Futuristic Clock Widget" 
        Height="140" Width="280"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseRightButtonDown="Window_MouseRightButtonDown"
        SizeChanged="Window_SizeChanged">
    
    <Window.Resources>
        <!-- Boolean to Visibility Converter -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        
        <!-- Neon Text Style -->
        <Style x:Key="NeonTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Light"/>
            <Setter Property="FontWeight" Value="UltraLight"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#00D4FF" 
                                      BlurRadius="15" 
                                      ShadowDepth="0" 
                                      Opacity="0.8"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Minimalist Date Style -->
        <Style x:Key="DateTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Semilight"/>
            <Setter Property="FontWeight" Value="Light"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#00D4FF" 
                                      BlurRadius="8" 
                                      ShadowDepth="0" 
                                      Opacity="0.5"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Small Info Style -->
        <Style x:Key="SmallInfoStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="Light"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="19.2"/>
            <Setter Property="Foreground" Value="#88FFFFFF"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#00D4FF" 
                                      BlurRadius="6" 
                                      ShadowDepth="0" 
                                      Opacity="0.4"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Liquid Animation -->
        <Storyboard x:Key="LiquidAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                           From="0.7" To="0.95" Duration="0:0:3"
                           AutoReverse="true">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>
    
        <!-- Enhanced Glassmorphism Container -->
    <Border x:Name="MainBackground" CornerRadius="24" 
            BorderThickness="1">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0D000000" Offset="0"/>
                <GradientStop Color="#15000000" Offset="0.5"/>
                <GradientStop Color="#0A000000" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#30FFFFFF" Offset="0"/>
                <GradientStop Color="#15FFFFFF" Offset="0.5"/>
                <GradientStop Color="#25FFFFFF" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.ContextMenu>
            <ContextMenu Background="#0F000000" Foreground="#00D4FF">
                <ContextMenu.Resources>
                    <Style TargetType="MenuItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#00D4FF"/>
                        <Setter Property="FontFamily" Value="Segoe UI Light"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="MenuItem">
                                    <Border x:Name="Border" Background="Transparent" BorderThickness="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ContentPresenter Grid.Column="0" Margin="8,0,8,0" VerticalAlignment="Center" ContentSource="Icon"/>
                                            <ContentPresenter Grid.Column="1" Margin="8,3,8,3" VerticalAlignment="Center" ContentSource="Header"/>
                                            <Popup Grid.Column="1" x:Name="SubMenuPopup" IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}" Placement="Right" PopupAnimation="Slide">
                                                <Border Background="#0F000000" BorderBrush="#3000D4FF" BorderThickness="1">
                                                    <Border.Resources>
                                                        <Style TargetType="MenuItem">
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Setter Property="Foreground" Value="#00D4FF"/>
                                                            <Setter Property="FontFamily" Value="Segoe UI Light"/>
                                                        </Style>
                                                    </Border.Resources>
                                                    <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                                </Border>
                                            </Popup>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#2000D4FF"/>
                                        </Trigger>
                                        <Trigger Property="IsSubmenuOpen" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#2000D4FF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                    <Style TargetType="Path" x:Key="IconPath">
                        <Setter Property="Fill" Value="#00D4FF"/>
                        <Setter Property="Stretch" Value="Uniform"/>
                        <Setter Property="Width" Value="12"/>
                        <Setter Property="Height" Value="12"/>
                        <Setter Property="Margin" Value="0"/>
                    </Style>
                    <Style TargetType="Separator">
                        <Setter Property="Background" Value="#3000D4FF"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Separator">
                                    <Rectangle Height="1" Fill="#3000D4FF" Margin="25,2,25,2"/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ContextMenu.Resources>
                <MenuItem Header="Size">
                    <MenuItem.Icon>
                        <Path Style="{StaticResource IconPath}" Data="M3 3h18v18H3V3zm16 16V5H5v14h14zM11 7h2v2h-2V7zm0 4h2v2h-2v-2zm0 4h2v2h-2v-2z"/>
                    </MenuItem.Icon>
                    <MenuItem Header="Small (200x100)" Click="SizeSmall_Click">
                        <MenuItem.Icon>
                            <Path Style="{StaticResource IconPath}" Data="M4 4h16v16H4V4zm14 14V6H6v12h12zM8 8h8v2H8V8zm0 4h8v2H8v-2z"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Medium (280x140)" Click="SizeMedium_Click">
                        <MenuItem.Icon>
                            <Path Style="{StaticResource IconPath}" Data="M4 4h16v16H4V4zm14 14V6H6v12h12zM8 8h8v4H8V8zm0 6h8v4H8v-4z"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Large (400x200)" Click="SizeLarge_Click">
                        <MenuItem.Icon>
                            <Path Style="{StaticResource IconPath}" Data="M3 3h18v18H3V3zm16 16V5H5v14h14zM7 7h10v2H7V7zm0 4h10v2H7v-2zm0 4h10v2H7v-2z"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Extra Large (600x300)" Click="SizeExtraLarge_Click">
                        <MenuItem.Icon>
                            <Path Style="{StaticResource IconPath}" Data="M2 2h20v20H2V2zm18 18V4H4v16h16zM6 6h12v2H6V6zm0 4h12v2H6v-2zm0 4h12v2H6v-2zm0 4h12v2H6v-2z"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Clock Type">
                    <MenuItem.Icon>
                        <Path Style="{StaticResource IconPath}" Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-1-13h2v6h-2zm0 8h2v2h-2z"/>
                    </MenuItem.Icon>
                    <MenuItem Header="Digital Clock" Click="DigitalClock_Click">
                        <MenuItem.Icon>
                            <Path Style="{StaticResource IconPath}" Data="M15 1H9v2h6V1zm-4 13h2V8h-2v6zm8.03-6.61l1.42-1.42c-.43-.51-.9-.99-1.41-1.41l-1.42 1.42C16.07 4.74 14.12 4 12 4c-4.97 0-9 4.03-9 9s4.02 9 9 9 9-4.03 9-9c0-2.12-.74-4.07-1.97-5.61zM12 20c-3.87 0-7-3.13-7-7s3.13-7 7-7 7 3.13 7 7-3.13 7-7 7z"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Analog Clock" Click="AnalogClock_Click">
                        <MenuItem.Icon>
                            <Path Style="{StaticResource IconPath}" Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Hour Markers">
                    <MenuItem.Icon>
                        <Path Style="{StaticResource IconPath}" Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-1-13h2v6h-2zm0 8h2v2h-2z"/>
                    </MenuItem.Icon>
                    <MenuItem Header="Cardinal (12, 3, 6, 9)" Click="CardinalMarkers_Click">
                        <MenuItem.Icon>
                            <Path Style="{StaticResource IconPath}" Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-1-13h2v6h-2zm0 8h2v2h-2z"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Full (All 12 Hours)" Click="FullMarkers_Click">
                        <MenuItem.Icon>
                            <Path Style="{StaticResource IconPath}" Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-1-13h2v6h-2zm0 8h2v2h-2z"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Time Format">
                    <MenuItem.Icon>
                        <Path Style="{StaticResource IconPath}" Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/>
                    </MenuItem.Icon>
                    <MenuItem Header="12-Hour (Normal)" Click="Format12Hour_Click">
                        <MenuItem.Icon>
                            <Path Style="{StaticResource IconPath}" Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-1-13h2v6h-2zm0 8h2v2h-2z"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="24-Hour (Military)" Click="Format24Hour_Click">
                        <MenuItem.Icon>
                            <Path Style="{StaticResource IconPath}" Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm1-13h-2v6l4.25 2.5.75-1.23-3.5-2.08z"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Display Options">
                    <MenuItem.Icon>
                        <Path Style="{StaticResource IconPath}" Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-1-13h2v6h-2zm0 8h2v2h-2z"/>
                    </MenuItem.Icon>
                    <MenuItem Header="Show Date" IsCheckable="True" IsChecked="{Binding ShowDate}" Click="ShowDate_Click"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Settings" Click="SettingsMenuItem_Click">
                    <MenuItem.Icon>
                        <Path Style="{StaticResource IconPath}" Data="M12 15.5A3.5 3.5 0 0 1 8.5 12A3.5 3.5 0 0 1 12 8.5a3.5 3.5 0 0 1 3.5 3.5a3.5 3.5 0 0 1-3.5 3.5m7.43-2.53c.04-.32.07-.64.07-.97c0-.33-.03-.65-.07-.97l2.11-1.63c.19-.15.24-.42.12-.64l-2-3.46c-.12-.22-.39-.3-.61-.22l-2.49 1c-.52-.39-1.06-.73-1.69-.98l-.37-2.65A.506.506 0 0 0 14 2h-4c-.25 0-.46.18-.5.42l-.37 2.65c-.63.25-1.17.59-1.69.98l-2.49-1c-.22-.08-.49 0-.61.22l-2 3.46c-.13.22-.07.49.12.64L4.57 11c-.04.32-.07.64-.07.97c0 .33.03.65.07.97l-2.11 1.63c-.19.15-.24.42-.12.64l2 3.46c.12.22.39.3.61.22l2.49-1c.52.39 1.06.73 1.69.98l.37 2.65c.04.24.25.42.5.42h4c.25 0 .46-.18.5-.42l.37-2.65c.63-.25 1.17-.59 1.69-.98l2.49 1c.22.08.49 0 .61-.22l2-3.46c.13-.22.07-.49-.12-.64l-2.11-1.63Z"/>
                    </MenuItem.Icon>
                </MenuItem>
                
                <!-- Appearance -->
                <MenuItem Header="Appearance">
                    <MenuItem.Icon>
                        <Path Style="{StaticResource IconPath}" Data="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </MenuItem.Icon>
                    <MenuItem Header="🎨 Background Color" 
                              Click="ChangeBackgroundColor_Click"/>
                    <MenuItem Header="🖌️ Base Color" 
                              Click="ChangeBaseColor_Click"/>
                    <MenuItem Header="🔄 Reset Colors" 
                              Click="ResetColors_Click"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Timer Widget" Click="OpenTimerWidget_Click">
                    <MenuItem.Icon>
                        <Path Style="{StaticResource IconPath}" Data="M15 1H9v2h6V1zm-4 13h2V8h-2v6zm8.03-6.61l1.42-1.42c-.43-.51-.9-.99-1.41-1.41l-1.42 1.42C16.07 4.74 14.12 4 12 4c-4.97 0-9 4.03-9 9s4.02 9 9 9 9-4.03 9-9c0-2.12-.74-4.07-1.97-5.61zM12 20c-3.87 0-7-3.13-7-7s3.13-7 7-7 7 3.13 7 7-3.13 7-7 7z"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Close" Click="CloseMenuItem_Click">
                    <MenuItem.Icon>
                        <Path Style="{StaticResource IconPath}" Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
                    </MenuItem.Icon>
                </MenuItem>
            </ContextMenu>
        </Border.ContextMenu>
        <Border.Effect>
            <DropShadowEffect Color="#00D4FF" 
                            BlurRadius="25" 
                            ShadowDepth="0" 
                            Opacity="0.4"/>
        </Border.Effect>
        
        <!-- Enhanced Glass Layers -->
        <Grid>
            <!-- Background Blur Layer -->
            <Border CornerRadius="22" Margin="1">
                <Border.Background>
                    <RadialGradientBrush>
                        <GradientStop Color="#0F111111" Offset="0"/>
                        <GradientStop Color="#0A222222" Offset="0.7"/>
                        <GradientStop Color="#05333333" Offset="1"/>
                    </RadialGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <BlurEffect Radius="8" KernelType="Gaussian"/>
                </Border.Effect>
                <Border.OpacityMask>
                    <RadialGradientBrush>
                        <GradientStop Color="#FFFFFF" Offset="0"/>
                        <GradientStop Color="#CCFFFFFF" Offset="0.8"/>
                        <GradientStop Color="#AAFFFFFF" Offset="1"/>
                    </RadialGradientBrush>
                </Border.OpacityMask>
            </Border>
            
            <!-- Glass Reflection Layer -->
            <Border CornerRadius="20" Margin="2">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#25FFFFFF" Offset="0"/>
                        <GradientStop Color="#10FFFFFF" Offset="0.3"/>
                        <GradientStop Color="#08FFFFFF" Offset="0.7"/>
                        <GradientStop Color="#15FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            
            <!-- Top Highlight Layer -->
            <Border CornerRadius="20" Margin="2" Height="20" VerticalAlignment="Top">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#40FFFFFF" Offset="0"/>
                        <GradientStop Color="#20FFFFFF" Offset="0.5"/>
                        <GradientStop Color="#00FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.OpacityMask>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FFFFFF" Offset="0"/>
                        <GradientStop Color="#FFFFFF" Offset="0.5"/>
                        <GradientStop Color="#00FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.OpacityMask>
            </Border>
            
            <!-- Content Layer -->
            <Grid Margin="25,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Digital Clock Content -->
                <Grid Grid.Row="0" Visibility="{Binding IsDigitalMode, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Time Display -->
                    <TextBlock Grid.Row="0"
                             x:Name="TimeTextBlock"
                             Text="{Binding FormattedTime}"
                             Style="{StaticResource NeonTextStyle}"
                             FontSize="57.6"
                             Foreground="#00D4FF">
                        <TextBlock.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard Storyboard="{StaticResource LiquidAnimation}"/>
                            </EventTrigger>
                        </TextBlock.Triggers>
                    </TextBlock>
                    
                    <!-- Full Date Display -->
                    <TextBlock Grid.Row="1"
                             Text="{Binding CurrentDate, StringFormat='{}{0:dddd, MMMM dd, yyyy}'}"
                             Style="{StaticResource DateTextStyle}"
                             FontSize="21.6"
                             Foreground="#CCFFFFFF"
                             Margin="0,2,0,0"
                             Visibility="{Binding ShowDate, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    
                    <!-- Additional Info Row -->
                    <Grid Grid.Row="2" Margin="0,3,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Week Number -->
                        <TextBlock Grid.Column="0"
                                 Text="{Binding WeekNumber}"
                                 Style="{StaticResource SmallInfoStyle}"/>
                        
                        <!-- Day of Year -->
                        <TextBlock Grid.Column="1"
                                 Text="{Binding DayOfYear}"
                                 Style="{StaticResource SmallInfoStyle}"/>
                    </Grid>
                    
                    <!-- Time Zone Info -->
                    <TextBlock Grid.Row="3"
                             Text="{Binding TimeZoneDisplay}"
                             Style="{StaticResource SmallInfoStyle}"
                             Margin="0,1,0,0"/>
                </Grid>
                
                <!-- Analog Clock Content -->
                <Grid Grid.Row="0" 
                      Visibility="{Binding IsAnalogMode, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Digital Time Display -->
                    <TextBlock Grid.Row="0"
                             x:Name="AnalogTimeTextBlock"
                             Text="{Binding FormattedTime}"
                             Style="{StaticResource NeonTextStyle}"
                             FontSize="24"
                             Foreground="#00D4FF"
                             Margin="0,0,0,8"
                             HorizontalAlignment="Center">
                        <TextBlock.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard Storyboard="{StaticResource LiquidAnimation}"/>
                            </EventTrigger>
                        </TextBlock.Triggers>
                    </TextBlock>
                    
                    <!-- Main Analog Clock Area -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.9*"/>
                            <ColumnDefinition Width="1.8*"/>
                            <ColumnDefinition Width="0.9*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Left Info Panel -->
                        <StackPanel Grid.Column="0" 
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,3,0">
                            <!-- Days Until -->
                            <Border CornerRadius="4" 
                                    Background="#10000000"
                                    BorderBrush="#3000D4FF"
                                    BorderThickness="1"
                                    Margin="0,0,0,3"
                                    Padding="5,2"
                                    MinWidth="48">
                                <TextBlock Text="{Binding DaysUntilEndOfYear}"
                                         FontSize="7"
                                         FontWeight="Normal"
                                         Foreground="#00D4FF"
                                         FontFamily="Segoe UI"
                                         TextAlignment="Center"
                                         TextWrapping="Wrap"
                                         LineHeight="8"/>
                            </Border>
                            
                            <!-- Weeks Elapsed -->
                            <Border CornerRadius="4" 
                                    Background="#10000000"
                                    BorderBrush="#3000D4FF"
                                    BorderThickness="1"
                                    Padding="5,2"
                                    MinWidth="48">
                                <TextBlock Text="{Binding WeeksElapsed}"
                                         FontSize="7"
                                         FontWeight="Normal"
                                         Foreground="#00D4FF"
                                         FontFamily="Segoe UI"
                                         TextAlignment="Center"
                                         LineHeight="8"/>
                            </Border>
                        </StackPanel>
                        
                        <!-- Center Analog Clock -->
                        <Canvas Grid.Column="1"
                                x:Name="AnalogClockCanvas"
                                Width="100" Height="100"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        
                            <!-- Clock Face Circle -->
                            <Ellipse x:Name="ClockFace"
                                     Width="100" Height="100" 
                                     Fill="Transparent"
                                     Stroke="#00D4FF" 
                                     StrokeThickness="1.5"
                                     Opacity="0.8"/>
                            
                            <!-- Hour Markers -->
                            <Canvas x:Name="HourMarkersCanvas" Width="100" Height="100"/>
                            
                            <!-- Hour Hand -->
                            <Line x:Name="HourHand" 
                                  X1="50" Y1="50" X2="50" Y2="25"
                                  Stroke="#00D4FF" 
                                  StrokeThickness="3" 
                                  Opacity="0.9">
                                <Line.Effect>
                                    <DropShadowEffect Color="#00D4FF" 
                                                      BlurRadius="6" 
                                                      ShadowDepth="0" 
                                                      Opacity="0.6"/>
                                </Line.Effect>
                            </Line>
                            
                            <!-- Minute Hand -->
                            <Line x:Name="MinuteHand" 
                                  X1="50" Y1="50" X2="50" Y2="18"
                                  Stroke="#00FFFF" 
                                  StrokeThickness="2" 
                                  Opacity="0.9">
                                <Line.Effect>
                                    <DropShadowEffect Color="#00FFFF" 
                                                      BlurRadius="5" 
                                                      ShadowDepth="0" 
                                                      Opacity="0.5"/>
                                </Line.Effect>
                            </Line>
                            
                            <!-- Second Hand -->
                            <Line x:Name="SecondHand" 
                                  X1="50" Y1="50" X2="50" Y2="12"
                                  Stroke="#FF6B6B" 
                                  StrokeThickness="0.8" 
                                  Opacity="0.8">
                                <Line.Effect>
                                    <DropShadowEffect Color="#FF6B6B" 
                                                      BlurRadius="3" 
                                                      ShadowDepth="0" 
                                                      Opacity="0.4"/>
                                </Line.Effect>
                            </Line>
                            
                            <!-- Center Dot -->
                            <Ellipse x:Name="CenterDot"
                                     Width="6" Height="6" 
                                     Fill="#00D4FF" 
                                     Canvas.Left="47" 
                                     Canvas.Top="47">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#00D4FF" 
                                                      BlurRadius="4" 
                                                      ShadowDepth="0" 
                                                      Opacity="0.8"/>
                                </Ellipse.Effect>
                            </Ellipse>
                        </Canvas>
                        
                        <!-- Right Info Panel -->
                        <StackPanel Grid.Column="2" 
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Margin="3,0,0,0">
                            <!-- Week Number -->
                            <Border CornerRadius="4" 
                                    Background="#10000000"
                                    BorderBrush="#3000D4FF"
                                    BorderThickness="1"
                                    Margin="0,0,0,3"
                                    Padding="5,2"
                                    MinWidth="48">
                                <TextBlock Text="{Binding WeekNumber}"
                                         FontSize="7"
                                         FontWeight="Normal"
                                         Foreground="#00D4FF"
                                         FontFamily="Segoe UI"
                                         TextAlignment="Center"
                                         LineHeight="8"/>
                            </Border>
                            
                            <!-- Day of Year -->
                            <Border CornerRadius="4" 
                                    Background="#10000000"
                                    BorderBrush="#3000D4FF"
                                    BorderThickness="1"
                                    Padding="5,2"
                                    MinWidth="48">
                                <TextBlock Text="{Binding DayOfYear}"
                                         FontSize="7"
                                         FontWeight="Normal"
                                         Foreground="#00D4FF"
                                         FontFamily="Segoe UI"
                                         TextAlignment="Center"
                                         LineHeight="8"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                    
                    <!-- Bottom Date Display -->
                    <Border Grid.Row="2"
                            CornerRadius="10"
                            Background="#0A000000"
                            BorderBrush="#2000D4FF"
                            BorderThickness="1"
                            Margin="0,8,0,0"
                            Padding="12,6"
                            Visibility="{Binding ShowDate, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{Binding CurrentDate, StringFormat='{}{0:dddd, MMMM dd, yyyy}'}"
                                 Style="{StaticResource DateTextStyle}"
                                 FontSize="13"
                                 Foreground="#CCFFFFFF"
                                 TextAlignment="Center"/>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
