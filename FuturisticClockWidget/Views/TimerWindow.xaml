<Window x:Class="FuturisticClockWidget.Views.TimerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Timer Widget" 
        Height="120" Width="280"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseRightButtonDown="Window_MouseRightButtonDown"
        SizeChanged="Window_SizeChanged">
    
    <Window.Resources>
        <!-- Neon Text Style -->
        <Style x:Key="NeonTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Light"/>
            <Setter Property="FontWeight" Value="UltraLight"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#00D4FF" 
                                      BlurRadius="15" 
                                      ShadowDepth="0" 
                                      Opacity="0.8"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Analog Clock Style -->
        <Style x:Key="AnalogClockStyle" TargetType="Canvas">
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="120"/>
        </Style>
        
        <!-- Timer Button Style -->
        <Style x:Key="TimerButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2000D4FF"/>
            <Setter Property="Foreground" Value="#00D4FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#4000D4FF"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="FontFamily" Value="Segoe UI Light"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4000D4FF"/>
                                <Setter Property="BorderBrush" Value="#6000D4FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#6000D4FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <!-- Enhanced Glassmorphism Container -->
    <Border x:Name="MainBackground" CornerRadius="24" 
            BorderThickness="1">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0D000000" Offset="0"/>
                <GradientStop Color="#15000000" Offset="0.5"/>
                <GradientStop Color="#0A000000" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#30FFFFFF" Offset="0"/>
                <GradientStop Color="#15FFFFFF" Offset="0.5"/>
                <GradientStop Color="#25FFFFFF" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.ContextMenu>
            <ContextMenu Background="#0F000000" Foreground="#00D4FF">
                <ContextMenu.Resources>
                    <Style TargetType="MenuItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#00D4FF"/>
                        <Setter Property="FontFamily" Value="Segoe UI Light"/>
                    </Style>
                    <Style TargetType="Path" x:Key="IconPath">
                        <Setter Property="Fill" Value="#00D4FF"/>
                        <Setter Property="Stretch" Value="Uniform"/>
                        <Setter Property="Width" Value="12"/>
                        <Setter Property="Height" Value="12"/>
                        <Setter Property="Margin" Value="0"/>
                    </Style>
                    <Style TargetType="Separator">
                        <Setter Property="Background" Value="#3000D4FF"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Separator">
                                    <Rectangle Height="1" Fill="#3000D4FF" Margin="25,2,25,2"/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ContextMenu.Resources>
                <MenuItem Header="Size">
                    <MenuItem.Icon>
                        <Path Style="{StaticResource IconPath}" Data="M3 3h18v18H3V3zm16 16V5H5v14h14zM11 7h2v2h-2V7zm0 4h2v2h-2v-2zm0 4h2v2h-2v-2z"/>
                    </MenuItem.Icon>
                    <MenuItem Header="Small (200x100)" Click="SizeSmall_Click">
                        <MenuItem.Icon>
                            <Path Style="{StaticResource IconPath}" Data="M4 4h16v16H4V4zm14 14V6H6v12h12zM8 8h8v2H8V8zm0 4h8v2H8v-2z"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Medium (280x120)" Click="SizeMedium_Click">
                        <MenuItem.Icon>
                            <Path Style="{StaticResource IconPath}" Data="M4 4h16v16H4V4zm14 14V6H6v12h12zM8 8h8v4H8V8zm0 6h8v4H8v-4z"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Large (400x180)" Click="SizeLarge_Click">
                        <MenuItem.Icon>
                            <Path Style="{StaticResource IconPath}" Data="M3 3h18v18H3V3zm16 16V5H5v14h14zM7 7h10v2H7V7zm0 4h10v2H7v-2zm0 4h10v2H7v-2z"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Extra Large (600x240)" Click="SizeExtraLarge_Click">
                        <MenuItem.Icon>
                            <Path Style="{StaticResource IconPath}" Data="M2 2h20v20H2V2zm18 18V4H4v16h16zM6 6h12v2H6V6zm0 4h12v2H6v-2zm0 4h12v2H6v-2zm0 4h12v2H6v-2z"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Toggle Analog/Digital" Click="ToggleAnalogDigital_Click">
                    <MenuItem.Icon>
                        <Path Fill="#00D4FF" Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-5.5-2.5l7.51-3.49L17.5 6.5 12 12z"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Reset Timer" Click="ResetTimer_Click">
                    <MenuItem.Icon>
                        <Path Fill="#00D4FF" Data="M12 5V1L7 6l5 5V7c3.31 0 6 2.69 6 6s-2.69 6-6 6-6-2.69-6-6z"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Set Timer" Click="SetTimer_Click">
                    <MenuItem.Icon>
                        <Path Fill="#00D4FF" Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-1-13h2v6h-2zm0 8h2v2h-2z"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Close" Click="CloseMenuItem_Click">
                    <MenuItem.Icon>
                        <Path Fill="#00D4FF" Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
                    </MenuItem.Icon>
                </MenuItem>
            </ContextMenu>
        </Border.ContextMenu>
        <Border.Effect>
            <DropShadowEffect Color="#00D4FF" 
                            BlurRadius="25" 
                            ShadowDepth="0" 
                            Opacity="0.4"/>
        </Border.Effect>
        
        <!-- Enhanced Glass Layers -->
        <Grid>
            <!-- Background Blur Layer -->
            <Border CornerRadius="22" Margin="1">
                <Border.Background>
                    <RadialGradientBrush>
                        <GradientStop Color="#0F111111" Offset="0"/>
                        <GradientStop Color="#0A222222" Offset="0.7"/>
                        <GradientStop Color="#05333333" Offset="1"/>
                    </RadialGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <BlurEffect Radius="8" KernelType="Gaussian"/>
                </Border.Effect>
                <Border.OpacityMask>
                    <RadialGradientBrush>
                        <GradientStop Color="#FFFFFF" Offset="0"/>
                        <GradientStop Color="#CCFFFFFF" Offset="0.8"/>
                        <GradientStop Color="#AAFFFFFF" Offset="1"/>
                    </RadialGradientBrush>
                </Border.OpacityMask>
            </Border>
            
            <!-- Glass Reflection Layer -->
            <Border CornerRadius="20" Margin="2">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#25FFFFFF" Offset="0"/>
                        <GradientStop Color="#10FFFFFF" Offset="0.3"/>
                        <GradientStop Color="#08FFFFFF" Offset="0.7"/>
                        <GradientStop Color="#15FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            
            <!-- Top Highlight Layer -->
            <Border CornerRadius="20" Margin="2" Height="20" VerticalAlignment="Top">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#40FFFFFF" Offset="0"/>
                        <GradientStop Color="#20FFFFFF" Offset="0.5"/>
                        <GradientStop Color="#00FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.OpacityMask>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FFFFFF" Offset="0"/>
                        <GradientStop Color="#FFFFFF" Offset="0.5"/>
                        <GradientStop Color="#00FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.OpacityMask>
            </Border>
            
            <!-- Content Layer -->
            <Grid Margin="25,15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
            
            <!-- Timer Display -->
            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Digital Display -->
                <Grid x:Name="DigitalDisplay" Grid.Row="0" Grid.RowSpan="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Timer Text -->
                    <TextBlock Grid.Row="0"
                             x:Name="TimerTextBlock"
                             Text="{Binding FormattedTime}"
                             Style="{StaticResource NeonTextStyle}"
                             FontSize="48"
                             Foreground="#00D4FF"
                             Margin="0,0,0,5"/>
                    
                    <!-- Timer Status -->
                    <TextBlock Grid.Row="1"
                             x:Name="StatusTextBlock"
                             Text="{Binding TimerStatus}"
                             FontFamily="Segoe UI Light"
                             FontSize="12"
                             FontWeight="Light"
                             Foreground="#CCFFFFFF"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"/>
                </Grid>
                
                <!-- Analog Display -->
                <Grid x:Name="AnalogDisplay" Grid.Row="0" Grid.RowSpan="2" Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <!-- Analog Clock -->
                        <Viewbox Stretch="Uniform" MaxWidth="120" MaxHeight="120" 
                                 HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Canvas Width="120" Height="120" x:Name="AnalogClock">
                                
                                <!-- Clock Face Background -->
                                <Ellipse Width="120" Height="120" Fill="#0A000000" Stroke="#4000D4FF" StrokeThickness="2"/>
                                
                                <!-- Inner ring for depth -->
                                <Ellipse Width="100" Height="100" Fill="Transparent" Stroke="#2000D4FF" StrokeThickness="1" 
                                         Canvas.Left="10" Canvas.Top="10"/>
                                
                                <!-- Hour Markers (12, 3, 6, 9) -->
                                <Rectangle Width="2" Height="12" Fill="#00D4FF" Canvas.Left="59" Canvas.Top="2"/>
                                <Rectangle Width="12" Height="2" Fill="#00D4FF" Canvas.Left="106" Canvas.Top="59"/>
                                <Rectangle Width="2" Height="12" Fill="#00D4FF" Canvas.Left="59" Canvas.Top="106"/>
                                <Rectangle Width="12" Height="2" Fill="#00D4FF" Canvas.Left="2" Canvas.Top="59"/>
                                
                                <!-- Additional Hour Markers (1, 2, 4, 5, 7, 8, 10, 11) -->
                                <Rectangle Width="1" Height="8" Fill="#6000D4FF" Canvas.Left="71" Canvas.Top="6"/>
                                <Rectangle Width="1" Height="8" Fill="#6000D4FF" Canvas.Left="81" Canvas.Top="6"/>
                                <Rectangle Width="1" Height="8" Fill="#6000D4FF" Canvas.Left="81" Canvas.Top="106"/>
                                <Rectangle Width="1" Height="8" Fill="#6000D4FF" Canvas.Left="71" Canvas.Top="106"/>
                                <Rectangle Width="1" Height="8" Fill="#6000D4FF" Canvas.Left="48" Canvas.Top="106"/>
                                <Rectangle Width="1" Height="8" Fill="#6000D4FF" Canvas.Left="38" Canvas.Top="106"/>
                                <Rectangle Width="1" Height="8" Fill="#6000D4FF" Canvas.Left="38" Canvas.Top="6"/>
                                <Rectangle Width="1" Height="8" Fill="#6000D4FF" Canvas.Left="48" Canvas.Top="6"/>
                                
                                <!-- Minute Markers -->
                                <Ellipse Width="2" Height="2" Fill="#4000D4FF" Canvas.Left="60" Canvas.Top="12"/>
                                <Ellipse Width="2" Height="2" Fill="#4000D4FF" Canvas.Left="90" Canvas.Top="18"/>
                                <Ellipse Width="2" Height="2" Fill="#4000D4FF" Canvas.Left="102" Canvas.Top="30"/>
                                <Ellipse Width="2" Height="2" Fill="#4000D4FF" Canvas.Left="102" Canvas.Top="48"/>
                                <Ellipse Width="2" Height="2" Fill="#4000D4FF" Canvas.Left="102" Canvas.Top="72"/>
                                <Ellipse Width="2" Height="2" Fill="#4000D4FF" Canvas.Left="102" Canvas.Top="90"/>
                                <Ellipse Width="2" Height="2" Fill="#4000D4FF" Canvas.Left="90" Canvas.Top="102"/>
                                <Ellipse Width="2" Height="2" Fill="#4000D4FF" Canvas.Left="60" Canvas.Top="102"/>
                                <Ellipse Width="2" Height="2" Fill="#4000D4FF" Canvas.Left="30" Canvas.Top="102"/>
                                <Ellipse Width="2" Height="2" Fill="#4000D4FF" Canvas.Left="18" Canvas.Top="102"/>
                                <Ellipse Width="2" Height="2" Fill="#4000D4FF" Canvas.Left="6" Canvas.Top="90"/>
                                <Ellipse Width="2" Height="2" Fill="#4000D4FF" Canvas.Left="6" Canvas.Top="72"/>
                                <Ellipse Width="2" Height="2" Fill="#4000D4FF" Canvas.Left="6" Canvas.Top="48"/>
                                <Ellipse Width="2" Height="2" Fill="#4000D4FF" Canvas.Left="6" Canvas.Top="30"/>
                                <Ellipse Width="2" Height="2" Fill="#4000D4FF" Canvas.Left="18" Canvas.Top="18"/>
                                <Ellipse Width="2" Height="2" Fill="#4000D4FF" Canvas.Left="90" Canvas.Top="18"/>
                                <Ellipse Width="2" Height="2" Fill="#4000D4FF" Canvas.Left="90" Canvas.Top="90"/>
                                <Ellipse Width="2" Height="2" Fill="#4000D4FF" Canvas.Left="18" Canvas.Top="90"/>
                                
                                <!-- Timer Progress Arc -->
                                <Path x:Name="ProgressArc" Stroke="#00D4FF" StrokeThickness="3" Fill="Transparent"/>
                                
                                <!-- Center Dot -->
                                <Ellipse Width="10" Height="10" Fill="#00D4FF" Canvas.Left="55" Canvas.Top="55">
                                    <Ellipse.Effect>
                                        <DropShadowEffect Color="#00D4FF" BlurRadius="8" ShadowDepth="0" Opacity="0.8"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                                
                                <!-- Timer Hand (points to current position) -->
                                <Line x:Name="TimerHand" X1="60" Y1="60" X2="60" Y2="20" 
                                      Stroke="#00D4FF" StrokeThickness="2" StrokeEndLineCap="Round">
                                    <Line.Effect>
                                        <DropShadowEffect Color="#00D4FF" BlurRadius="4" ShadowDepth="0" Opacity="0.6"/>
                                    </Line.Effect>
                                </Line>
                            </Canvas>
                        </Viewbox>
                        
                        <!-- Digital Time Overlay -->
                        <Border Background="#0A000000" 
                                CornerRadius="8" 
                                Padding="12,6"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="0,8,0,0"
                                MinWidth="80">
                            <Border.Effect>
                                <DropShadowEffect Color="#00D4FF" 
                                                  BlurRadius="8" 
                                                  ShadowDepth="0" 
                                                  Opacity="0.6"/>
                            </Border.Effect>
                            <TextBlock x:Name="AnalogDigitalOverlay"
                                     Text="{Binding FormattedTime}"
                                     FontFamily="Segoe UI Light"
                                     FontSize="16"
                                     FontWeight="UltraLight"
                                     Foreground="#00D4FF"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#00D4FF" 
                                                      BlurRadius="6" 
                                                      ShadowDepth="0" 
                                                      Opacity="1.0"/>
                                </TextBlock.Effect>
                            </TextBlock>
                        </Border>
                        
                        <!-- Timer Status -->
                        <TextBlock x:Name="AnalogStatusTextBlock"
                                 Text="{Binding TimerStatus}"
                                 FontFamily="Segoe UI Light"
                                 FontSize="12"
                                 FontWeight="Light"
                                 Foreground="#CCFFFFFF"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 Margin="0,5,0,0"/>
                    </StackPanel>
                </Grid>
            </Grid>
            
            <!-- Control Buttons -->
            <StackPanel Grid.Row="1" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Center"
                        Margin="0,10,0,0">
                <Button x:Name="StartPauseButton"
                        Content="▶️ Start"
                        Style="{StaticResource TimerButtonStyle}"
                        Click="StartPause_Click"/>
                <Button x:Name="ResetButton"
                        Content="🔄 Reset"
                        Style="{StaticResource TimerButtonStyle}"
                        Click="Reset_Click"/>
                <Button x:Name="SetButton"
                        Content="Set"
                        Style="{StaticResource TimerButtonStyle}"
                        Click="Set_Click"/>
            </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
