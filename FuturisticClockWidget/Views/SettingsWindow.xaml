<Window x:Class="FuturisticClockWidget.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Futuristic Clock Widget - Settings" 
        Height="600" Width="500"
        WindowStartupLocation="CenterScreen"
        Background="#0A0A0A"
        ResizeMode="NoResize">
    
    <Window.Resources>
        <!-- Futuristic Button Style -->
        <Style x:Key="FuturisticButton" TargetType="Button">
            <Setter Property="Background" Value="#10000000"/>
            <Setter Property="Foreground" Value="#00D4FF"/>
            <Setter Property="BorderBrush" Value="#3000D4FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI Light"/>
            <Setter Property="FontWeight" Value="Light"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <Border.Effect>
                                <DropShadowEffect Color="#00D4FF" BlurRadius="5" ShadowDepth="0" Opacity="0.3"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2000D4FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#3000D4FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Futuristic CheckBox Style -->
        <Style x:Key="FuturisticCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontFamily" Value="Segoe UI Light"/>
            <Setter Property="FontWeight" Value="Light"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="CheckBorder" 
                                    Width="16" Height="16" 
                                    Background="#10000000"
                                    BorderBrush="#3000D4FF" 
                                    BorderThickness="1"
                                    CornerRadius="2"
                                    Margin="0,0,8,0">
                                <Border.Effect>
                                    <DropShadowEffect Color="#00D4FF" BlurRadius="3" ShadowDepth="0" Opacity="0.2"/>
                                </Border.Effect>
                                <Path x:Name="CheckMark" 
                                      Data="M3,7 L7,11 L13,3" 
                                      Stroke="#00D4FF" 
                                      StrokeThickness="2" 
                                      Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="CheckBorder" Property="Background" Value="#2000D4FF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBorder" Property="Background" Value="#15000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Section Header Style -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Semilight"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Light"/>
            <Setter Property="Foreground" Value="#00D4FF"/>
            <Setter Property="Margin" Value="0,15,0,10"/>
        </Style>
        
        <!-- Label Style -->
        <Style x:Key="FuturisticLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Light"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Light"/>
            <Setter Property="Foreground" Value="#CCFFFFFF"/>
            <Setter Property="Margin" Value="5"/>
        </Style>
    </Window.Resources>
    
    <Border BorderBrush="#3000D4FF" BorderThickness="1" CornerRadius="8" Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="#00D4FF" BlurRadius="15" ShadowDepth="0" Opacity="0.2"/>
        </Border.Effect>
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Title -->
            <TextBlock Grid.Row="0" Text="Widget Settings" 
                       FontFamily="Segoe UI Light" FontSize="24" 
                       FontWeight="UltraLight" 
                       Foreground="#00D4FF" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,20"/>
            
            <!-- Settings Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Clock Settings -->
                    <TextBlock Text="Clock Settings" Style="{StaticResource SectionHeader}"/>
                    
                    <StackPanel Margin="10,0">
                        <CheckBox x:Name="StartupCheckBox" Content="Start with Windows" 
                                  Style="{StaticResource FuturisticCheckBox}"/>
                        <CheckBox x:Name="HourFormat24CheckBox" Content="24-Hour Format" 
                                  Style="{StaticResource FuturisticCheckBox}"/>
                        <CheckBox x:Name="ShowSecondsCheckBox" Content="Show Seconds" 
                                  Style="{StaticResource FuturisticCheckBox}"/>
                        <CheckBox x:Name="ShowDateCheckBox" Content="Show Date" 
                                  Style="{StaticResource FuturisticCheckBox}"/>
                        <CheckBox x:Name="ShowWeekNumberCheckBox" Content="Show Week Number" 
                                  Style="{StaticResource FuturisticCheckBox}"/>
                        <CheckBox x:Name="ShowDayOfYearCheckBox" Content="Show Day of Year" 
                                  Style="{StaticResource FuturisticCheckBox}"/>
                        <CheckBox x:Name="ShowTimeZoneCheckBox" Content="Show Time Zone" 
                                  Style="{StaticResource FuturisticCheckBox}"/>
                    </StackPanel>
                    
                    <!-- Appearance Settings -->
                    <TextBlock Text="Appearance" Style="{StaticResource SectionHeader}"/>
                    
                    <StackPanel Margin="10,0">
                        <TextBlock Text="Opacity:" Style="{StaticResource FuturisticLabel}"/>
                        <Slider x:Name="OpacitySlider" Minimum="0.1" Maximum="1.0" Value="0.9" 
                                TickFrequency="0.1" IsSnapToTickEnabled="True" 
                                Margin="5" Height="30"/>
                        <TextBlock x:Name="OpacityValueText" Text="90%" 
                                   Style="{StaticResource FuturisticLabel}" 
                                   HorizontalAlignment="Center"/>
                        
                        <TextBlock Text="Font Scale:" Style="{StaticResource FuturisticLabel}" Margin="5,10,5,5"/>
                        <Slider x:Name="FontScaleSlider" Minimum="0.5" Maximum="2.0" Value="1.0" 
                                TickFrequency="0.1" IsSnapToTickEnabled="True" 
                                Margin="5" Height="30"/>
                        <TextBlock x:Name="FontScaleValueText" Text="100%" 
                                   Style="{StaticResource FuturisticLabel}" 
                                   HorizontalAlignment="Center"/>
                        
                        <CheckBox x:Name="GlassEffectCheckBox" Content="Enable Glass Effect" 
                                  Style="{StaticResource FuturisticCheckBox}" Margin="5,10,5,5"/>
                        <CheckBox x:Name="AnimationsCheckBox" Content="Enable Animations" 
                                  Style="{StaticResource FuturisticCheckBox}"/>
                    </StackPanel>
                    
                    <!-- Window Settings -->
                    <TextBlock Text="Window" Style="{StaticResource SectionHeader}"/>
                    
                    <StackPanel Margin="10,0">
                        <CheckBox x:Name="TopmostCheckBox" Content="Always on Top" 
                                  Style="{StaticResource FuturisticCheckBox}"/>
                        <CheckBox x:Name="ShowInTaskbarCheckBox" Content="Show in Taskbar" 
                                  Style="{StaticResource FuturisticCheckBox}"/>
                    </StackPanel>
                    
                    <!-- Advanced Settings -->
                    <TextBlock Text="Advanced" Style="{StaticResource SectionHeader}"/>
                    
                    <StackPanel Margin="10,0">
                        <CheckBox x:Name="LoggingCheckBox" Content="Enable Logging" 
                                  Style="{StaticResource FuturisticCheckBox}"/>
                        <CheckBox x:Name="UpdatesCheckBox" Content="Check for Updates" 
                                  Style="{StaticResource FuturisticCheckBox}"/>
                        <CheckBox x:Name="NotificationsCheckBox" Content="Show Notifications" 
                                  Style="{StaticResource FuturisticCheckBox}"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
            
            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" 
                        HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button x:Name="ResetButton" Content="Reset to Defaults" 
                        Style="{StaticResource FuturisticButton}" 
                        Click="ResetButton_Click"/>
                <Button x:Name="CancelButton" Content="Cancel" 
                        Style="{StaticResource FuturisticButton}" 
                        Click="CancelButton_Click"/>
                <Button x:Name="SaveButton" Content="Save" 
                        Style="{StaticResource FuturisticButton}" 
                        Click="SaveButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
