<Window x:Class="FuturisticClockWidget.Views.TimerInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Set Timer" 
        Height="200" Width="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E1E"
        Foreground="#FF6B6B">
    
    <Window.Resources>
        <!-- Input Style -->
        <Style x:Key="TimerInputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#FF6B6B"/>
            <Setter Property="BorderBrush" Value="#40FF6B6B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Width" Value="60"/>
        </Style>
        
        <!-- Label Style -->
        <Style x:Key="TimerLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Light"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#CCFF6B6B"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="5"/>
        </Style>
        
        <!-- Button Style -->
        <Style x:Key="TimerDialogButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#20FF6B6B"/>
            <Setter Property="Foreground" Value="#FF6B6B"/>
            <Setter Property="BorderBrush" Value="#40FF6B6B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontFamily" Value="Segoe UI Light"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#40FF6B6B"/>
                                <Setter Property="BorderBrush" Value="#60FF6B6B"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#60FF6B6B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Border CornerRadius="8" 
            Background="#252526" 
            BorderBrush="#40FF6B6B" 
            BorderThickness="1"
            Margin="10">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Title -->
            <TextBlock Grid.Row="0"
                       Text="Set Timer Duration"
                       FontFamily="Segoe UI Light"
                       FontSize="18"
                       FontWeight="Light"
                       Foreground="#FF6B6B"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>
            
            <!-- Input Section -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Hours -->
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBox x:Name="HoursTextBox"
                             Style="{StaticResource TimerInputStyle}"
                             Text="0"
                             MaxLength="2"
                             PreviewTextInput="NumberValidationTextBox"/>
                    <TextBlock Text="Hours"
                               Style="{StaticResource TimerLabelStyle}"/>
                </StackPanel>
                
                <!-- Minutes -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBox x:Name="MinutesTextBox"
                             Style="{StaticResource TimerInputStyle}"
                             Text="5"
                             MaxLength="2"
                             PreviewTextInput="NumberValidationTextBox"/>
                    <TextBlock Text="Minutes"
                               Style="{StaticResource TimerLabelStyle}"/>
                </StackPanel>
                
                <!-- Seconds -->
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBox x:Name="SecondsTextBox"
                             Style="{StaticResource TimerInputStyle}"
                             Text="0"
                             MaxLength="2"
                             PreviewTextInput="NumberValidationTextBox"/>
                    <TextBlock Text="Seconds"
                               Style="{StaticResource TimerLabelStyle}"/>
                </StackPanel>
            </Grid>
            
            <!-- Buttons -->
            <StackPanel Grid.Row="2" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Center"
                        Margin="0,20,0,0">
                <Button Content="OK"
                        Style="{StaticResource TimerDialogButtonStyle}"
                        Click="OK_Click"
                        IsDefault="True"/>
                <Button Content="Cancel"
                        Style="{StaticResource TimerDialogButtonStyle}"
                        Click="Cancel_Click"
                        IsCancel="True"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
