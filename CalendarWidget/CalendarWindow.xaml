<Window x:Class="CalendarWidget.CalendarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Calendar Widget" 
        Height="320" Width="280"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseRightButtonDown="Window_MouseRightButtonDown"
        SizeChanged="Window_SizeChanged">
    
    <Window.Resources>
        <!-- Boolean to Visibility Converter -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        
        <!-- Futuristic Calendar Header Style -->
        <Style x:Key="CalendarHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Light"/>
            <Setter Property="FontWeight" Value="UltraLight"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="Foreground" Value="#00D4FF"/>
            <Setter Property="Margin" Value="0,8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#00D4FF" 
                                      BlurRadius="12" 
                                      ShadowDepth="0" 
                                      Opacity="0.7"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Futuristic Day Number Style -->
        <Style x:Key="DayNumberStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" 
                                      BlurRadius="2" 
                                      ShadowDepth="1" 
                                      Opacity="0.8"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Futuristic Today Day Style -->
        <Style x:Key="TodayDayStyle" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <RadialGradientBrush>
                        <GradientStop Color="#4000D4FF" Offset="0"/>
                        <GradientStop Color="#2500D4FF" Offset="0.7"/>
                        <GradientStop Color="#1500D4FF" Offset="1"/>
                    </RadialGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="BorderBrush" Value="#00D4FF"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#00D4FF" 
                                      BlurRadius="10" 
                                      ShadowDepth="0" 
                                      Opacity="0.8"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Futuristic Weekend Day Style -->
        <Style x:Key="WeekendDayStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Foreground" Value="#7DD3FC"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" 
                                      BlurRadius="2" 
                                      ShadowDepth="1" 
                                      Opacity="0.8"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Enhanced Liquid Animation -->
        <Storyboard x:Key="LiquidAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                           From="0.8" To="1.0" Duration="0:0:4"
                           AutoReverse="true">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        
        <!-- Pulse Animation for Today -->
        <Storyboard x:Key="PulseAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                           From="0.6" To="1.0" Duration="0:0:2"
                           AutoReverse="true">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        
        <!-- Small Info Style -->
        <Style x:Key="SmallInfoStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="Light"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#88FFFFFF"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#00D4FF" 
                                      BlurRadius="3" 
                                      ShadowDepth="0" 
                                      Opacity="0.3"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Day Number Shadow Effect -->
        <DropShadowEffect x:Key="DayNumberShadowEffect" Color="#000000" 
                          BlurRadius="2" 
                          ShadowDepth="1" 
                          Opacity="0.8"/>
    </Window.Resources>
    
    <!-- Enhanced Glassmorphism Container -->
    <Border CornerRadius="24" BorderThickness="1">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0D000000" Offset="0"/>
                <GradientStop Color="#15000000" Offset="0.5"/>
                <GradientStop Color="#0A000000" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#30FFFFFF" Offset="0"/>
                <GradientStop Color="#15FFFFFF" Offset="0.5"/>
                <GradientStop Color="#25FFFFFF" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.ContextMenu>
            <ContextMenu Background="#0F000000" Foreground="#00D4FF">
                <ContextMenu.Resources>
                    <Style TargetType="MenuItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#00D4FF"/>
                        <Setter Property="FontFamily" Value="Segoe UI Light"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="MenuItem">
                                    <Border x:Name="Border" Background="Transparent" BorderThickness="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ContentPresenter Grid.Column="0" Margin="8,0,8,0" VerticalAlignment="Center" ContentSource="Icon"/>
                                            <ContentPresenter Grid.Column="1" Margin="8,3,8,3" VerticalAlignment="Center" ContentSource="Header"/>
                                            <Popup Grid.Column="1" x:Name="SubMenuPopup" IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}" Placement="Right" PopupAnimation="Slide">
                                                <Border Background="#0F000000" BorderBrush="#3000D4FF" BorderThickness="1">
                                                    <Border.Resources>
                                                        <Style TargetType="MenuItem">
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Setter Property="Foreground" Value="#00D4FF"/>
                                                            <Setter Property="FontFamily" Value="Segoe UI Light"/>
                                                        </Style>
                                                    </Border.Resources>
                                                    <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                                </Border>
                                            </Popup>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#2000D4FF"/>
                                        </Trigger>
                                        <Trigger Property="IsSubmenuOpen" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#2000D4FF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                    <Style TargetType="Path" x:Key="IconPath">
                        <Setter Property="Fill" Value="#00D4FF"/>
                        <Setter Property="Stretch" Value="Uniform"/>
                        <Setter Property="Width" Value="12"/>
                        <Setter Property="Height" Value="12"/>
                        <Setter Property="Margin" Value="0"/>
                    </Style>
                    <Style TargetType="Separator">
                        <Setter Property="Background" Value="#3000D4FF"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Separator">
                                    <Rectangle Height="1" Fill="#3000D4FF" Margin="25,2,25,2"/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ContextMenu.Resources>
                
                <!-- Size Menu -->
                <MenuItem Header="Size">
                    <MenuItem.Icon>
                        <Path Style="{StaticResource IconPath}" Data="M3 3h18v18H3zm16 16V5H5v14h14zM11 7h2v2h-2V7zm0 4h2v2h-2v-2zm0 4h2v2h-2z"/>
                    </MenuItem.Icon>
                    <MenuItem Header="Small (200x250)" Click="SizeSmall_Click"/>
                    <MenuItem Header="Medium (280x320)" Click="SizeMedium_Click"/>
                    <MenuItem Header="Large (400x450)" Click="SizeLarge_Click"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Close" Click="CloseMenuItem_Click"/>
            </ContextMenu>
        </Border.ContextMenu>
        <Border.Effect>
            <DropShadowEffect Color="#00D4FF" 
                            BlurRadius="25" 
                            ShadowDepth="0" 
                            Opacity="0.4"/>
        </Border.Effect>
        
        <!-- Enhanced Glass Layers -->
        <Grid>
            <!-- Background Blur Layer -->
            <Border CornerRadius="22" Margin="1">
                <Border.Background>
                    <RadialGradientBrush>
                        <GradientStop Color="#0F111111" Offset="0"/>
                        <GradientStop Color="#0A222222" Offset="0.7"/>
                        <GradientStop Color="#05333333" Offset="1"/>
                    </RadialGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <BlurEffect Radius="8" KernelType="Gaussian"/>
                </Border.Effect>
                <Border.OpacityMask>
                    <RadialGradientBrush>
                        <GradientStop Color="#FFFFFF" Offset="0"/>
                        <GradientStop Color="#CCFFFFFF" Offset="0.8"/>
                        <GradientStop Color="#AAFFFFFF" Offset="1"/>
                    </RadialGradientBrush>
                </Border.OpacityMask>
            </Border>
            
            <!-- Glass Reflection Layer -->
            <Border CornerRadius="20" Margin="2">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#25FFFFFF" Offset="0"/>
                        <GradientStop Color="#10FFFFFF" Offset="0.3"/>
                        <GradientStop Color="#08FFFFFF" Offset="0.7"/>
                        <GradientStop Color="#15FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.OpacityMask>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FFFFFF" Offset="0"/>
                        <GradientStop Color="#FFFFFF" Offset="0.5"/>
                        <GradientStop Color="#00FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.OpacityMask>
            </Border>
            
            <!-- Enhanced Content Layer -->
            <Grid Margin="20,25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Calendar Header with Navigation -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Previous Month Button -->
                    <Button Grid.Column="0" 
                            x:Name="PreviousMonthButton"
                            Content="◀" 
                            Background="Transparent" 
                            BorderBrush="#3000D4FF" 
                            BorderThickness="1"
                            Foreground="#00D4FF" 
                            FontSize="14" 
                            Width="28" Height="24"
                            Cursor="Hand"
                            Click="PreviousMonth_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        BorderBrush="{TemplateBinding BorderBrush}" 
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="12"
                                        Cursor="Hand">
                                    <ContentPresenter HorizontalAlignment="Center" 
                                                    VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2000D4FF"/>
                                        <Setter Property="BorderBrush" Value="#00D4FF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    
                    <!-- Current Month Year -->
                    <TextBlock Grid.Column="1"
                             Text="{Binding CurrentMonthYear}"
                             Style="{StaticResource CalendarHeaderStyle}">
                        <TextBlock.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard Storyboard="{StaticResource LiquidAnimation}"/>
                            </EventTrigger>
                        </TextBlock.Triggers>
                    </TextBlock>
                    
                    <!-- Next Month Button -->
                    <Button Grid.Column="2" 
                            x:Name="NextMonthButton"
                            Content="▶" 
                            Background="Transparent" 
                            BorderBrush="#3000D4FF" 
                            BorderThickness="1"
                            Foreground="#00D4FF" 
                            FontSize="14" 
                            Width="28" Height="24"
                            Cursor="Hand"
                            Click="NextMonth_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        BorderBrush="{TemplateBinding BorderBrush}" 
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="12"
                                        Cursor="Hand">
                                    <ContentPresenter HorizontalAlignment="Center" 
                                                    VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2000D4FF"/>
                                        <Setter Property="BorderBrush" Value="#00D4FF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
                
                <!-- Calendar Grid -->
                <Grid Grid.Row="1" Margin="0,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Week Day Headers -->
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Text="SUN" Style="{StaticResource DayNumberStyle}" FontWeight="Bold" Foreground="#7DD3FC" FontSize="12"/>
                        <TextBlock Grid.Column="1" Text="MON" Style="{StaticResource DayNumberStyle}" FontWeight="Bold" Foreground="#00D4FF" FontSize="12"/>
                        <TextBlock Grid.Column="2" Text="TUE" Style="{StaticResource DayNumberStyle}" FontWeight="Bold" Foreground="#00D4FF" FontSize="12"/>
                        <TextBlock Grid.Column="3" Text="WED" Style="{StaticResource DayNumberStyle}" FontWeight="Bold" Foreground="#00D4FF" FontSize="12"/>
                        <TextBlock Grid.Column="4" Text="THU" Style="{StaticResource DayNumberStyle}" FontWeight="Bold" Foreground="#00D4FF" FontSize="12"/>
                        <TextBlock Grid.Column="5" Text="FRI" Style="{StaticResource DayNumberStyle}" FontWeight="Bold" Foreground="#00D4FF" FontSize="12"/>
                        <TextBlock Grid.Column="6" Text="SAT" Style="{StaticResource DayNumberStyle}" FontWeight="Bold" Foreground="#7DD3FC" FontSize="12"/>
                    </Grid>
                    
                    <!-- Calendar Days Grid -->
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding CalendarDays}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="7" Rows="6"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="DayBorder"
                                       Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                       Margin="0.5"
                                       CornerRadius="12"
                                       BorderThickness="1.5"
                                       BorderBrush="#00D4FF"
                                       Background="Transparent">
                                    <TextBlock x:Name="DayText" Text="{Binding DayNumber}" 
                                             FontFamily="Segoe UI Semibold"
                                             FontWeight="SemiBold"
                                             FontSize="16"
                                             Foreground="#FFFFFF"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Effect="{StaticResource DayNumberShadowEffect}"/>
                                </Border>
                                <DataTemplate.Triggers>
                                    <!-- Today trigger -->
                                    <DataTrigger Binding="{Binding IsToday}" Value="True">
                                        <Setter TargetName="DayBorder" Property="Background">
                                            <Setter.Value>
                                                <RadialGradientBrush>
                                                    <GradientStop Color="#4000D4FF" Offset="0"/>
                                                    <GradientStop Color="#2500D4FF" Offset="0.7"/>
                                                    <GradientStop Color="#1500D4FF" Offset="1"/>
                                                </RadialGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter TargetName="DayBorder" Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect Color="#00D4FF" 
                                                                  BlurRadius="10" 
                                                                  ShadowDepth="0" 
                                                                  Opacity="0.8"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <!-- Weekend trigger -->
                                    <DataTrigger Binding="{Binding IsWeekend}" Value="True">
                                        <Setter TargetName="DayBorder" Property="BorderBrush" Value="#7DD3FC"/>
                                        <Setter Property="Foreground" Value="#7DD3FC" TargetName="DayText"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
                
                <!-- Enhanced Current Date Info -->
                <Border Grid.Row="2" 
                        CornerRadius="12"
                        Background="#0A000000"
                        BorderBrush="#2000D4FF"
                        BorderThickness="1"
                        Margin="0,10,0,5"
                        Padding="12,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Current Date Display -->
                        <TextBlock Grid.Row="0"
                                 Text="{Binding CurrentDate, StringFormat='{}{0:dddd, MMMM dd, yyyy}'}"
                                 FontFamily="Segoe UI Semilight"
                                 FontSize="16"
                                 FontWeight="Light"
                                 Foreground="#CCFFFFFF"
                                 TextAlignment="Center"
                                 Margin="0,0,0,4"/>
                        
                        <!-- Additional Info Grid -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Week Info -->
                            <Border Grid.Column="0" 
                                    CornerRadius="6"
                                    Background="#05000000"
                                    BorderBrush="#1500D4FF"
                                    BorderThickness="0.5"
                                    Margin="0,0,2,0"
                                    Padding="4,2">
                                <StackPanel>
                                    <TextBlock Text="{Binding WeekNumber}"
                                             Style="{StaticResource SmallInfoStyle}"/>
                                    <TextBlock Text="Week"
                                             Style="{StaticResource SmallInfoStyle}"
                                             FontSize="12"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- Day of Year -->
                            <Border Grid.Column="1" 
                                    CornerRadius="6"
                                    Background="#05000000"
                                    BorderBrush="#1500D4FF"
                                    BorderThickness="0.5"
                                    Margin="1,0,2,0"
                                    Padding="4,2">
                                <StackPanel>
                                    <TextBlock Text="{Binding DayOfYear}"
                                             Style="{StaticResource SmallInfoStyle}"/>
                                    <TextBlock Text="Day"
                                             Style="{StaticResource SmallInfoStyle}"
                                             FontSize="12"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- Days Left in Year -->
                            <Border Grid.Column="2" 
                                    CornerRadius="6"
                                    Background="#05000000"
                                    BorderBrush="#1500D4FF"
                                    BorderThickness="0.5"
                                    Margin="2,0,0,0"
                                    Padding="4,2">
                                <StackPanel>
                                    <TextBlock Text="{Binding DaysUntilEndOfYear}"
                                             Style="{StaticResource SmallInfoStyle}"/>
                                    <TextBlock Text="Left"
                                             Style="{StaticResource SmallInfoStyle}"
                                             FontSize="12"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
                
                <!-- Additional Calendar Info -->
                <Border Grid.Row="3" 
                        CornerRadius="10"
                        Background="#08000000"
                        BorderBrush="#1500D4FF"
                        BorderThickness="0.5"
                        Margin="0,0,0,5"
                        Padding="10,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Moon Phase -->
                        <StackPanel Grid.Column="0" 
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <TextBlock Text="🌙" 
                                     FontSize="14" 
                                     VerticalAlignment="Center"
                                     Margin="0,0,4,0"/>
                            <TextBlock Text="{Binding MoonPhase}"
                                     Style="{StaticResource SmallInfoStyle}"
                                     FontSize="13"/>
                        </StackPanel>
                        
                        <!-- Season -->
                        <StackPanel Grid.Column="1" 
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <TextBlock Text="{Binding SeasonIcon}" 
                                     FontSize="14" 
                                     VerticalAlignment="Center"
                                     Margin="0,0,4,0"/>
                            <TextBlock Text="{Binding Season}"
                                     Style="{StaticResource SmallInfoStyle}"
                                     FontSize="13"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
