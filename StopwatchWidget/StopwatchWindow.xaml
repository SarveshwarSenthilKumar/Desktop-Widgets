<Window x:Class="StopwatchWidget.StopwatchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StopwatchWidget"
        mc:Ignorable="d"
        Title="Stopwatch" 
        Height="200" Width="320"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseRightButtonDown="Window_MouseRightButtonDown"
        SizeChanged="Window_SizeChanged">
    
    <Window.Resources>
        <!-- Boolean to Visibility Converter -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        
        <!-- Futuristic Stopwatch Style -->
        <Style x:Key="StopwatchHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Light"/>
            <Setter Property="FontWeight" Value="UltraLight"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="#00D4FF"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#00D4FF" 
                                      BlurRadius="8" 
                                      ShadowDepth="0" 
                                      Opacity="0.7"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Stopwatch Time Display Style -->
        <Style x:Key="TimeDisplayStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" 
                                      BlurRadius="2" 
                                      ShadowDepth="1" 
                                      Opacity="0.8"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Button Style -->
        <Style x:Key="StopwatchButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#3000D4FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#00D4FF"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Light"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2000D4FF"/>
                                <Setter Property="BorderBrush" Value="#00D4FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Lap Time Style -->
        <Style x:Key="LapTimeStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="Light"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Foreground" Value="#CCFFFFFF"/>
            <Setter Property="Margin" Value="3,1"/>
        </Style>
    </Window.Resources>
    
    <!-- Enhanced Glassmorphism Container -->
    <Border x:Name="MainBackground" CornerRadius="20" BorderThickness="1">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0D000000" Offset="0"/>
                <GradientStop Color="#15000000" Offset="0.5"/>
                <GradientStop Color="#0A000000" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#30FFFFFF" Offset="0"/>
                <GradientStop Color="#15FFFFFF" Offset="0.5"/>
                <GradientStop Color="#25FFFFFF" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.ContextMenu>
            <ContextMenu Background="#0A000000" Foreground="#00D4FF">
                <!-- Size Menu -->
                <MenuItem Header="Size" InputGestureText="">
                    <MenuItem Header="Small" 
                              InputGestureText="Ctrl+1" 
                              Click="SizeSmall_Click"/>
                    <MenuItem Header="Medium" 
                              InputGestureText="Ctrl+2" 
                              Click="SizeMedium_Click"/>
                    <MenuItem Header="Large" 
                              InputGestureText="Ctrl+3" 
                              Click="SizeLarge_Click"/>
                </MenuItem>
                
                <!-- Appearance -->
                <MenuItem Header="Appearance" InputGestureText="">
                    <MenuItem Header="Toggle Analog/Digital" 
                              Click="ToggleAnalogDigital_Click"/>
                    <Separator/>
                    <MenuItem Header="Background Color" 
                              Click="ChangeBackgroundColor_Click"/>
                    <MenuItem Header="Base Color" 
                              Click="ChangeBaseColor_Click"/>
                    <MenuItem Header="Reset Colors" 
                              Click="ResetColors_Click"/>
                </MenuItem>
                
                <Separator/>
                
                <!-- Actions -->
                <MenuItem Header="Reset" 
                          InputGestureText="Ctrl+R" 
                          Click="Reset_Click"/>
                <MenuItem Header="Clear Laps" 
                          InputGestureText="Ctrl+L" 
                          Click="ClearLaps_Click"/>
                
                <Separator/>
                
                <!-- Close -->
                <MenuItem Header="Close" 
                          InputGestureText="Alt+F4" 
                          Click="CloseMenuItem_Click"/>
            </ContextMenu>
        </Border.ContextMenu>
        <Border.Effect>
            <DropShadowEffect Color="#00D4FF" 
                            BlurRadius="20" 
                            ShadowDepth="0" 
                            Opacity="0.4"/>
        </Border.Effect>
        
        <!-- Content Grid -->
        <Grid Margin="10,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <TextBlock Grid.Row="0" 
                       Text="STOPWATCH" 
                       Style="{StaticResource StopwatchHeaderStyle}"
                       Margin="0,0,0,5"/>
            
            <!-- Time Display -->
            <!-- Digital Display -->
            <Grid x:Name="DigitalDisplay" Grid.Row="1">
                <TextBlock x:Name="TimeDisplay"
                         Text="{Binding ElapsedTimeString}"
                         Style="{StaticResource TimeDisplayStyle}"
                         Margin="0,5"/>
            </Grid>
            
            <!-- Analog Display -->
            <Grid x:Name="AnalogDisplay" Grid.Row="1" Visibility="Collapsed">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <!-- Analog Stopwatch -->
                    <Viewbox Stretch="Uniform" MaxWidth="100" MaxHeight="100" 
                             HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Canvas Width="100" Height="100" x:Name="AnalogStopwatch">
                            
                            <!-- Clock Face Background -->
                            <Ellipse Width="100" Height="100" Fill="#0A000000" Stroke="#4000D4FF" StrokeThickness="2"/>
                            
                            <!-- Inner ring for depth -->
                            <Ellipse Width="80" Height="80" Fill="Transparent" Stroke="#2000D4FF" StrokeThickness="1" 
                                     Canvas.Left="10" Canvas.Top="10"/>
                            
                            <!-- Hour Markers (12, 3, 6, 9) -->
                            <Rectangle Width="2" Height="10" Fill="#00D4FF" Canvas.Left="49" Canvas.Top="2"/>
                            <Rectangle Width="10" Height="2" Fill="#00D4FF" Canvas.Left="88" Canvas.Top="49"/>
                            <Rectangle Width="2" Height="10" Fill="#00D4FF" Canvas.Left="49" Canvas.Top="88"/>
                            <Rectangle Width="10" Height="2" Fill="#00D4FF" Canvas.Left="2" Canvas.Top="49"/>
                            
                            <!-- Additional Hour Markers (1, 2, 4, 5, 7, 8, 10, 11) -->
                            <Rectangle Width="1" Height="6" Fill="#6000D4FF" Canvas.Left="59" Canvas.Top="5"/>
                            <Rectangle Width="1" Height="6" Fill="#6000D4FF" Canvas.Left="67" Canvas.Top="5"/>
                            <Rectangle Width="1" Height="6" Fill="#6000D4FF" Canvas.Left="67" Canvas.Top="89"/>
                            <Rectangle Width="1" Height="6" Fill="#6000D4FF" Canvas.Left="59" Canvas.Top="89"/>
                            <Rectangle Width="1" Height="6" Fill="#6000D4FF" Canvas.Left="40" Canvas.Top="89"/>
                            <Rectangle Width="1" Height="6" Fill="#6000D4FF" Canvas.Left="31" Canvas.Top="89"/>
                            <Rectangle Width="1" Height="6" Fill="#6000D4FF" Canvas.Left="31" Canvas.Top="5"/>
                            <Rectangle Width="1" Height="6" Fill="#6000D4FF" Canvas.Left="40" Canvas.Top="5"/>
                            
                            <!-- Minute Markers -->
                            <Ellipse Width="1.5" Height="1.5" Fill="#4000D4FF" Canvas.Left="50" Canvas.Top="10"/>
                            <Ellipse Width="1.5" Height="1.5" Fill="#4000D4FF" Canvas.Left="75" Canvas.Top="15"/>
                            <Ellipse Width="1.5" Height="1.5" Fill="#4000D4FF" Canvas.Left="85" Canvas.Top="25"/>
                            <Ellipse Width="1.5" Height="1.5" Fill="#4000D4FF" Canvas.Left="85" Canvas.Top="50"/>
                            <Ellipse Width="1.5" Height="1.5" Fill="#4000D4FF" Canvas.Left="85" Canvas.Top="75"/>
                            <Ellipse Width="1.5" Height="1.5" Fill="#4000D4FF" Canvas.Left="75" Canvas.Top="85"/>
                            <Ellipse Width="1.5" Height="1.5" Fill="#4000D4FF" Canvas.Left="50" Canvas.Top="85"/>
                            <Ellipse Width="1.5" Height="1.5" Fill="#4000D4FF" Canvas.Left="25" Canvas.Top="85"/>
                            <Ellipse Width="1.5" Height="1.5" Fill="#4000D4FF" Canvas.Left="15" Canvas.Top="85"/>
                            <Ellipse Width="1.5" Height="1.5" Fill="#4000D4FF" Canvas.Left="15" Canvas.Top="75"/>
                            <Ellipse Width="1.5" Height="1.5" Fill="#4000D4FF" Canvas.Left="10" Canvas.Top="50"/>
                            <Ellipse Width="1.5" Height="1.5" Fill="#4000D4FF" Canvas.Left="25" Canvas.Top="50"/>
                            <Ellipse Width="1.5" Height="1.5" Fill="#4000D4FF" Canvas.Left="50" Canvas.Top="25"/>
                            <Ellipse Width="1.5" Height="1.5" Fill="#4000D4FF" Canvas.Left="10" Canvas.Top="10"/>
                            
                            <!-- Center Dot -->
                            <Ellipse Width="8" Height="8" Fill="#00D4FF" Canvas.Left="46" Canvas.Top="46">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#00D4FF" BlurRadius="6" ShadowDepth="0" Opacity="0.8"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            
                            <!-- Stopwatch Hand (points to current seconds position) -->
                            <Line x:Name="StopwatchHand" X1="50" Y1="50" X2="50" Y2="15" 
                                  Stroke="#00D4FF" StrokeThickness="1.5" StrokeEndLineCap="Round">
                                <Line.Effect>
                                    <DropShadowEffect Color="#00D4FF" BlurRadius="3" ShadowDepth="0" Opacity="0.6"/>
                                </Line.Effect>
                            </Line>
                        </Canvas>
                    </Viewbox>
                    
                    <!-- Digital Time Overlay -->
                    <Border Background="#0A000000" 
                            CornerRadius="6" 
                            Padding="8,4"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="0,5,0,0"
                            MinWidth="60">
                        <Border.Effect>
                            <DropShadowEffect Color="#00D4FF" 
                                              BlurRadius="6" 
                                              ShadowDepth="0" 
                                              Opacity="0.6"/>
                        </Border.Effect>
                        <TextBlock x:Name="AnalogDigitalOverlay"
                                 Text="{Binding ElapsedTimeString}"
                                 FontFamily="Segoe UI Light"
                                 FontSize="14"
                                 FontWeight="UltraLight"
                                 Foreground="#00D4FF"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#00D4FF" 
                                                  BlurRadius="4" 
                                                  ShadowDepth="0" 
                                                  Opacity="1.0"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Grid>
            
            <!-- Control Buttons -->
            <Grid Grid.Row="2" Margin="0,5,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Button Grid.Column="0" 
                        x:Name="StartStopButton"
                        Content="Start" 
                        Style="{StaticResource StopwatchButtonStyle}"
                        Padding="6,3"
                        FontSize="11"
                        Click="StartStop_Click"/>
                
                <Button Grid.Column="1" 
                        x:Name="LapButton"
                        Content="Lap" 
                        Style="{StaticResource StopwatchButtonStyle}"
                        IsEnabled="False"
                        Padding="6,3"
                        FontSize="11"
                        Click="Lap_Click"/>
                
                <Button Grid.Column="2" 
                        Content="Reset" 
                        Style="{StaticResource StopwatchButtonStyle}"
                        Padding="6,3"
                        FontSize="11"
                        Click="Reset_Click"/>
            </Grid>
            
            <!-- Lap Times -->
            <ScrollViewer Grid.Row="3" 
                          x:Name="LapTimesScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          MaxHeight="80"
                          Visibility="{Binding HasLapTimes, Converter={StaticResource BoolToVisibilityConverter}}">
                <ItemsControl ItemsSource="{Binding LapTimes}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding LapNumber, StringFormat='Lap {0}:'}" 
                                           Style="{StaticResource LapTimeStyle}"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding LapTime}" 
                                           Style="{StaticResource LapTimeStyle}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            
            <!-- Status -->
            <TextBlock Grid.Row="4" 
                       x:Name="StatusDisplay"
                       Text="{Binding Status}"
                       Style="{StaticResource LapTimeStyle}"
                       HorizontalAlignment="Center"
                       Margin="0,5,0,0"/>
        </Grid>
    </Border>
</Window>
