<Window x:Class="StopwatchWidget.StopwatchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StopwatchWidget"
        mc:Ignorable="d"
        Title="Stopwatch" 
        Height="200" Width="320"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseRightButtonDown="Window_MouseRightButtonDown"
        SizeChanged="Window_SizeChanged">
    
    <Window.Resources>
        <!-- Boolean to Visibility Converter -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        
        <!-- Futuristic Stopwatch Style -->
        <Style x:Key="StopwatchHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Light"/>
            <Setter Property="FontWeight" Value="UltraLight"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="#00D4FF"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#00D4FF" 
                                      BlurRadius="8" 
                                      ShadowDepth="0" 
                                      Opacity="0.7"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Stopwatch Time Display Style -->
        <Style x:Key="TimeDisplayStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" 
                                      BlurRadius="2" 
                                      ShadowDepth="1" 
                                      Opacity="0.8"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Button Style -->
        <Style x:Key="StopwatchButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#3000D4FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#00D4FF"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Light"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2000D4FF"/>
                                <Setter Property="BorderBrush" Value="#00D4FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Lap Time Style -->
        <Style x:Key="LapTimeStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="Light"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#CCFFFFFF"/>
            <Setter Property="Margin" Value="5,1"/>
        </Style>
    </Window.Resources>
    
    <!-- Enhanced Glassmorphism Container -->
    <Border x:Name="MainBackground" CornerRadius="20" BorderThickness="1">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0D000000" Offset="0"/>
                <GradientStop Color="#15000000" Offset="0.5"/>
                <GradientStop Color="#0A000000" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#30FFFFFF" Offset="0"/>
                <GradientStop Color="#15FFFFFF" Offset="0.5"/>
                <GradientStop Color="#25FFFFFF" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.ContextMenu>
            <ContextMenu Background="#0A000000" Foreground="#00D4FF">
                <!-- Size Menu -->
                <MenuItem Header="Size" InputGestureText="">
                    <MenuItem Header="Small" 
                              InputGestureText="Ctrl+1" 
                              Click="SizeSmall_Click"/>
                    <MenuItem Header="Medium" 
                              InputGestureText="Ctrl+2" 
                              Click="SizeMedium_Click"/>
                    <MenuItem Header="Large" 
                              InputGestureText="Ctrl+3" 
                              Click="SizeLarge_Click"/>
                </MenuItem>
                
                <!-- Appearance -->
                <MenuItem Header="Appearance" InputGestureText="">
                    <MenuItem Header="Background Color" 
                              Click="ChangeBackgroundColor_Click"/>
                    <MenuItem Header="Base Color" 
                              Click="ChangeBaseColor_Click"/>
                    <MenuItem Header="Reset Colors" 
                              Click="ResetColors_Click"/>
                </MenuItem>
                
                <Separator/>
                
                <!-- Actions -->
                <MenuItem Header="Reset" 
                          InputGestureText="Ctrl+R" 
                          Click="Reset_Click"/>
                <MenuItem Header="Clear Laps" 
                          InputGestureText="Ctrl+L" 
                          Click="ClearLaps_Click"/>
                
                <Separator/>
                
                <!-- Close -->
                <MenuItem Header="Close" 
                          InputGestureText="Alt+F4" 
                          Click="CloseMenuItem_Click"/>
            </ContextMenu>
        </Border.ContextMenu>
        <Border.Effect>
            <DropShadowEffect Color="#00D4FF" 
                            BlurRadius="20" 
                            ShadowDepth="0" 
                            Opacity="0.4"/>
        </Border.Effect>
        
        <!-- Content Grid -->
        <Grid Margin="20,15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <TextBlock Grid.Row="0" 
                       Text="STOPWATCH" 
                       Style="{StaticResource StopwatchHeaderStyle}"/>
            
            <!-- Time Display -->
            <TextBlock Grid.Row="1" 
                       x:Name="TimeDisplay"
                       Text="{Binding ElapsedTimeString}"
                       Style="{StaticResource TimeDisplayStyle}"
                       Margin="0,10"/>
            
            <!-- Control Buttons -->
            <Grid Grid.Row="2" Margin="0,10,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Button Grid.Column="0" 
                        x:Name="StartStopButton"
                        Content="Start" 
                        Style="{StaticResource StopwatchButtonStyle}"
                        Click="StartStop_Click"/>
                
                <Button Grid.Column="1" 
                        x:Name="LapButton"
                        Content="Lap" 
                        Style="{StaticResource StopwatchButtonStyle}"
                        IsEnabled="False"
                        Click="Lap_Click"/>
                
                <Button Grid.Column="2" 
                        Content="Reset" 
                        Style="{StaticResource StopwatchButtonStyle}"
                        Click="Reset_Click"/>
            </Grid>
            
            <!-- Lap Times -->
            <ScrollViewer Grid.Row="3" 
                          x:Name="LapTimesScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Visibility="{Binding HasLapTimes, Converter={StaticResource BoolToVisibilityConverter}}">
                <ItemsControl ItemsSource="{Binding LapTimes}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding LapNumber, StringFormat='Lap {0}:'}" 
                                           Style="{StaticResource LapTimeStyle}"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding LapTime}" 
                                           Style="{StaticResource LapTimeStyle}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            
            <!-- Status -->
            <TextBlock Grid.Row="4" 
                       x:Name="StatusDisplay"
                       Text="{Binding Status}"
                       Style="{StaticResource LapTimeStyle}"
                       HorizontalAlignment="Center"
                       Margin="0,5,0,0"/>
        </Grid>
    </Border>
</Window>
