<Window x:Class="WeatherWidget.WeatherSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WeatherWidget"
        xmlns:models="clr-namespace:WeatherWidget.Models"
        mc:Ignorable="d"
        Title="Weather Settings" 
        Height="500" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E1E"
        Foreground="#FFFFFF">
    
    <Window.Resources>
        <!-- Modern Text Style -->
        <Style x:Key="HeaderStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Light"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Light"/>
            <Setter Property="Foreground" Value="#00D4FF"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- Label Style -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Light"/>
            <Setter Property="Foreground" Value="#CCFFFFFF"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <!-- Input Style -->
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#4000D4FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                        Margin="{TemplateBinding Padding}"
                                        VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox Style -->
        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#4000D4FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- Button Style -->
        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2000D4FF"/>
            <Setter Property="Foreground" Value="#00D4FF"/>
            <Setter Property="BorderBrush" Value="#4000D4FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontFamily" Value="Segoe UI Light"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4000D4FF"/>
                                <Setter Property="BorderBrush" Value="#6000D4FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#6000D4FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CheckBox Style -->
        <Style x:Key="CheckBoxStyle" TargetType="CheckBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#CCFFFFFF"/>
            <Setter Property="Margin" Value="0,5"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="8" 
            Background="#252526" 
            BorderBrush="#4000D4FF" 
            BorderThickness="1"
            Margin="10">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Grid.Row="0"
                       Text="Weather Settings"
                       Style="{StaticResource HeaderStyle}"
                       Margin="0,0,0,20"/>

            <!-- Settings Content -->
            <ScrollViewer Grid.Row="1" 
                          VerticalScrollBarVisibility="Auto" 
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <!-- Location Settings -->
                    <TextBlock Text="Location" Style="{StaticResource HeaderStyle}" FontSize="14"/>
                    
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="City:" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="CityTextBox" 
                                     Style="{StaticResource InputStyle}"
                                     Text="{Binding City}"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Country:" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="CountryTextBox" 
                                     Style="{StaticResource InputStyle}"
                                     Text="{Binding Country}"/>
                        </StackPanel>
                    </Grid>

                    <!-- API Settings -->
                    <TextBlock Text="API Configuration" Style="{StaticResource HeaderStyle}" FontSize="14"/>
                    
                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Text="OpenWeatherMap API Key:" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="ApiKeyTextBox" 
                                 Style="{StaticResource InputStyle}"
                                 Text="{Binding ApiKey}"
                                 Height="60"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="False"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                        <TextBlock Text="Get your free API key from: https://openweathermap.org/api" 
                                   Style="{StaticResource LabelStyle}" 
                                   FontSize="10" 
                                   Foreground="#66FFFFFF"/>
                    </StackPanel>

                    <!-- Display Settings -->
                    <TextBlock Text="Display Options" Style="{StaticResource HeaderStyle}" FontSize="14"/>
                    
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Temperature Unit:" Style="{StaticResource LabelStyle}"/>
                            <ComboBox x:Name="TemperatureUnitComboBox" 
                                      Style="{StaticResource ComboBoxStyle}"
                                      SelectedItem="{Binding TemperatureUnit}">
                                <ComboBoxItem Content="Celsius" Tag="{x:Static models:TemperatureUnit.Celsius}"/>
                                <ComboBoxItem Content="Fahrenheit" Tag="{x:Static models:TemperatureUnit.Fahrenheit}"/>
                            </ComboBox>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Wind Speed Unit:" Style="{StaticResource LabelStyle}"/>
                            <ComboBox x:Name="WindSpeedUnitComboBox" 
                                      Style="{StaticResource ComboBoxStyle}"
                                      SelectedItem="{Binding WindSpeedUnit}">
                                <ComboBoxItem Content="km/h" Tag="{x:Static models:WindSpeedUnit.Kph}"/>
                                <ComboBoxItem Content="mph" Tag="{x:Static models:WindSpeedUnit.Mph}"/>
                                <ComboBoxItem Content="m/s" Tag="{x:Static models:WindSpeedUnit.Ms}"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,0,0,15">
                        <CheckBox x:Name="ShowForecastCheckBox" 
                                  Style="{StaticResource CheckBoxStyle}"
                                  IsChecked="{Binding ShowForecast}">
                            Show 5-day forecast
                        </CheckBox>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                            <TextBlock Text="Forecast Days:" Style="{StaticResource LabelStyle}" Margin="0,0,10,0"/>
                            <ComboBox x:Name="ForecastDaysComboBox" 
                                      Style="{StaticResource ComboBoxStyle}"
                                      Width="60"
                                      SelectedItem="{Binding ForecastDays}">
                                <ComboBoxItem Content="3"/>
                                <ComboBoxItem Content="5"/>
                                <ComboBoxItem Content="7"/>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>

                    <!-- Refresh Settings -->
                    <TextBlock Text="Refresh Interval" Style="{StaticResource HeaderStyle}" FontSize="14"/>
                    
                    <StackPanel Margin="0,0,0,15">
                        <ComboBox x:Name="RefreshIntervalComboBox" 
                                  Style="{StaticResource ComboBoxStyle}"
                                  SelectedItem="{Binding RefreshInterval}">
                            <ComboBoxItem Content="5 minutes" Tag="{x:Static models:RefreshInterval.FiveMinutes}"/>
                            <ComboBoxItem Content="15 minutes" Tag="{x:Static models:RefreshInterval.FifteenMinutes}"/>
                            <ComboBoxItem Content="30 minutes" Tag="{x:Static models:RefreshInterval.ThirtyMinutes}"/>
                            <ComboBoxItem Content="1 hour" Tag="{x:Static models:RefreshInterval.OneHour}"/>
                            <ComboBoxItem Content="2 hours" Tag="{x:Static models:RefreshInterval.TwoHours}"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Notification Settings -->
                    <TextBlock Text="Notifications" Style="{StaticResource HeaderStyle}" FontSize="14"/>
                    
                    <StackPanel>
                        <CheckBox x:Name="EnableNotificationsCheckBox" 
                                  Style="{StaticResource CheckBoxStyle}"
                                  IsChecked="{Binding EnableNotifications}">
                            Enable weather notifications
                        </CheckBox>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                            <TextBlock Text="Alert Threshold (°C):" Style="{StaticResource LabelStyle}" Margin="0,0,10,0"/>
                            <TextBox x:Name="NotificationThresholdTextBox" 
                                     Style="{StaticResource InputStyle}"
                                     Width="80"
                                     Text="{Binding NotificationThreshold}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Right"
                        Margin="0,20,0,0">
                <Button Content="Cancel" 
                        Style="{StaticResource ButtonStyle}"
                        Click="CancelButton_Click"/>
                <Button Content="OK" 
                        Style="{StaticResource ButtonStyle}"
                        Click="OkButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
